<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>UCURide — Universidad Católica del Uruguay</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
:root{
  --blue:    #003087;
  --blue2:   #1a5276;
  --blue3:   #2e86c1;
  --accent:  #1abc9c;
  --gold:    #f0c040;
  --red:     #e74c3c;
  --green:   #1abc9c;
  --bg:      #f0f4f9;
  --card:    #ffffff;
  --text:    #0d1b2a;
  --muted:   #6b82a0;
  --border:  #d5e0ee;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;font-family:'Plus Jakarta Sans',sans-serif;color:var(--text);}
body{background:var(--bg);overflow:hidden;}

/* ══════════════════════
   AUTH OVERLAY
══════════════════════ */
#authWrap{
  position:fixed;inset:0;z-index:1000;
  display:flex;align-items:stretch;
  transition:opacity .4s;
}
#authWrap.gone{opacity:0;pointer-events:none;}

/* Left panel — hero */
.auth-hero{
  flex:1;background:var(--blue);position:relative;overflow:hidden;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:40px;
}
.auth-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 60% 40%,rgba(26,188,156,.18),transparent 70%);}

/* campus scene SVG */
.campus-scene{width:100%;max-width:520px;position:relative;z-index:1;}

/* UCU shield */
.ucu-shield-wrap{
  position:absolute;top:24px;left:24px;z-index:5;
  display:flex;align-items:center;gap:12px;
}
.ucu-shield{width:52px;height:52px;}
.ucu-brand{color:white;}
.ucu-brand-name{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;line-height:1;}
.ucu-brand-sub{font-size:10px;opacity:.5;letter-spacing:1.2px;text-transform:uppercase;}

.auth-hero-title{
  font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(26px,3.5vw,42px);
  color:white;text-align:center;line-height:1.2;margin-top:28px;position:relative;z-index:1;
}
.auth-hero-title span{color:var(--accent);}
.auth-hero-sub{font-size:14px;color:rgba(255,255,255,.5);margin-top:10px;text-align:center;position:relative;z-index:1;}

/* pill stats */
.hero-pills{display:flex;gap:10px;margin-top:24px;flex-wrap:wrap;justify-content:center;position:relative;z-index:1;}
.hero-pill{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);backdrop-filter:blur(6px);border-radius:30px;padding:8px 16px;font-size:12px;font-weight:600;color:rgba(255,255,255,.8);display:flex;align-items:center;gap:6px;}
.hero-pill span{font-family:'Syne',sans-serif;font-weight:800;color:var(--accent);}

/* Right panel — form */
.auth-form-panel{
  width:420px;flex-shrink:0;background:var(--bg);
  display:flex;flex-direction:column;justify-content:center;
  padding:40px 36px;overflow-y:auto;
}
.auth-form-logo{display:flex;align-items:center;gap:10px;margin-bottom:28px;}
.auth-form-logo-icon{width:40px;height:40px;background:var(--blue);border-radius:10px;display:flex;align-items:center;justify-content:center;}
.auth-form-logo-icon svg{width:22px;height:22px;fill:white;}
.auth-form-logo-text{font-family:'Syne',sans-serif;font-weight:800;font-size:20px;color:var(--blue);}
.auth-form-logo-text em{color:var(--accent);font-style:normal;}

.auth-tab-row{display:flex;background:var(--border);border-radius:12px;padding:3px;margin-bottom:24px;}
.auth-tab{flex:1;padding:9px;text-align:center;border-radius:9px;font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:var(--muted);cursor:pointer;transition:all .2s;}
.auth-tab.active{background:var(--card);color:var(--blue);box-shadow:0 2px 8px rgba(0,0,0,.08);}

.auth-title{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;color:var(--text);margin-bottom:4px;}
.auth-sub{font-size:13px;color:var(--muted);margin-bottom:20px;}

.fg{display:flex;flex-direction:column;gap:5px;margin-bottom:12px;}
.fl{font-family:'Syne',sans-serif;font-weight:700;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;}
.fi{background:var(--card);border:2px solid var(--border);border-radius:12px;padding:11px 14px;font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;color:var(--text);outline:none;transition:border-color .2s;width:100%;}
.fi:focus{border-color:var(--blue3);}

.abtn{width:100%;background:var(--blue);color:white;border:none;border-radius:12px;padding:13px;font-family:'Syne',sans-serif;font-weight:800;font-size:15px;cursor:pointer;margin-top:4px;transition:background .2s;}
.abtn:hover{background:var(--blue2);}
.alink{text-align:center;font-size:12px;color:var(--muted);margin-top:10px;}
.alink span{color:var(--blue3);font-weight:700;cursor:pointer;}

/* mobile: stack auth vertically */
@media(max-width:700px){
  #authWrap{flex-direction:column;}
  .auth-hero{min-height:240px;flex:none;padding:20px;}
  .auth-form-panel{width:100%;flex:1;padding:24px 20px;}
  .campus-scene{max-width:300px;}
  .ucu-shield-wrap{top:14px;left:14px;}
  .auth-hero-title{font-size:22px;margin-top:12px;}
}

/* ══════════════════════
   APP SHELL
══════════════════════ */
#appWrap{position:fixed;inset:0;display:none;flex-direction:row;}
#appWrap.visible{display:flex;}

/* SIDEBAR */
#sidebar{
  width:250px;flex-shrink:0;background:var(--blue);
  display:flex;flex-direction:column;padding-bottom:16px;
  transition:transform .3s;z-index:200;
}
.sb-logo{padding:22px 18px 18px;border-bottom:1px solid rgba(255,255,255,.1);display:flex;align-items:center;gap:10px;}
.sb-logo-icon{width:38px;height:38px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sb-logo-icon svg{width:22px;height:22px;fill:white;}
.sb-logo-text{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;color:white;}
.sb-logo-text em{color:var(--accent);font-style:normal;}
.sb-logo-sub{font-size:9px;color:rgba(255,255,255,.35);letter-spacing:1.4px;text-transform:uppercase;display:block;margin-top:1px;}

.sb-user{margin:10px;background:rgba(255,255,255,.07);border-radius:12px;padding:12px 14px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:background .2s;}
.sb-user:hover{background:rgba(255,255,255,.12);}
.sb-user-av{width:36px;height:36px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sb-user-av svg{width:20px;height:20px;fill:white;}
.sb-user-name{font-weight:700;font-size:13px;color:white;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-user-role{font-size:10px;color:rgba(255,255,255,.4);}

.sb-nav{flex:1;padding:6px 10px;display:flex;flex-direction:column;gap:2px;}
.sb-item{display:flex;align-items:center;gap:10px;padding:10px 13px;border-radius:10px;cursor:pointer;border:none;background:none;width:100%;text-align:left;transition:background .2s;}
.sb-item:hover{background:rgba(255,255,255,.07);}
.sb-item.active{background:rgba(255,255,255,.13);}
.sb-item svg{width:18px;height:18px;fill:none;stroke:rgba(255,255,255,.45);stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;}
.sb-item.active svg{stroke:var(--accent);}
.sb-item span{font-size:13px;font-weight:600;color:rgba(255,255,255,.5);}
.sb-item.active span{color:white;}

.sb-footer{padding:0 10px;}
.sb-logout{display:flex;align-items:center;gap:8px;padding:10px 13px;border-radius:10px;cursor:pointer;border:none;background:none;width:100%;color:rgba(255,255,255,.35);font-size:13px;font-weight:600;transition:all .2s;}
.sb-logout:hover{background:rgba(231,76,60,.15);color:#e74c3c;}
.sb-logout svg{width:16px;height:16px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;}

/* MAIN */
#appMain{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;}

/* TOPBAR */
#topbar{
  height:56px;background:var(--card);border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;padding:0 24px;flex-shrink:0;z-index:100;
}
.tb-title{font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--blue);display:flex;align-items:center;gap:8px;}
.tb-right{display:flex;align-items:center;gap:12px;}
.tb-date{font-size:12px;color:var(--muted);}
.tb-av{width:32px;height:32px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;}
.tb-av svg{width:16px;height:16px;fill:none;stroke:white;stroke-width:2;stroke-linecap:round;}
.tb-menu{display:none;background:none;border:none;cursor:pointer;padding:4px;}
.tb-menu svg{width:20px;height:20px;fill:none;stroke:var(--blue);stroke-width:2;stroke-linecap:round;}

/* PAGES */
#pages{flex:1;overflow:hidden;position:relative;}
.page{position:absolute;inset:0;overflow-y:auto;padding:24px;opacity:0;pointer-events:none;transform:translateY(6px);transition:opacity .28s,transform .28s;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.page.active{opacity:1;pointer-events:all;transform:translateY(0);}
.page::-webkit-scrollbar{width:4px;}
.page::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}

/* BOTTOM NAV (mobile) */
#bnav{display:none;position:fixed;bottom:0;left:0;right:0;height:60px;background:var(--blue);z-index:300;align-items:center;justify-content:space-around;padding:0 6px;}
.bn{display:flex;flex-direction:column;align-items:center;gap:2px;background:none;border:none;cursor:pointer;padding:5px 10px;border-radius:10px;}
.bn.active{background:rgba(255,255,255,.1);}
.bn svg{width:20px;height:20px;fill:none;stroke:rgba(255,255,255,.4);stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.bn.active svg{stroke:var(--accent);}
.bn span{font-size:10px;color:rgba(255,255,255,.4);font-weight:600;}
.bn.active span{color:var(--accent);}

#sbo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:199;}

/* ══════════════════════
   COMPONENTS
══════════════════════ */
.col{display:flex;flex-direction:column;gap:16px;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}

.card{background:var(--card);border-radius:18px;padding:18px;box-shadow:0 2px 10px rgba(0,48,135,.06);}
.card-title{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:var(--text);margin-bottom:14px;}

.hero-banner{background:var(--blue);border-radius:18px;padding:22px;display:flex;align-items:center;justify-content:space-between;position:relative;overflow:hidden;}
.hero-banner::before{content:'';position:absolute;right:-20px;top:-20px;width:110px;height:110px;background:var(--accent);opacity:.12;border-radius:50%;}
.hero-banner::after{content:'';position:absolute;right:50px;bottom:-30px;width:80px;height:80px;background:var(--blue3);opacity:.1;border-radius:50%;}
.hb-text h2{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(15px,1.6vw,20px);color:white;line-height:1.3;}
.hb-text p{font-size:12px;color:rgba(255,255,255,.45);margin-top:5px;}
.hb-icon{width:52px;height:52px;background:var(--accent);border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1;}
.hb-icon svg{width:28px;height:28px;fill:white;}

.stat-card{background:var(--card);border-radius:16px;padding:16px;box-shadow:0 2px 10px rgba(0,48,135,.06);}
.sc-icon{width:38px;height:38px;border-radius:11px;display:flex;align-items:center;justify-content:center;margin-bottom:6px;}
.sc-icon svg{width:20px;height:20px;}
.sc-num{font-family:'Syne',sans-serif;font-weight:800;font-size:24px;color:var(--blue);}
.sc-lbl{font-size:11px;color:var(--muted);}

.co2-card{background:linear-gradient(135deg,#062a1e,#0a3d2b);border-radius:18px;padding:18px;position:relative;overflow:hidden;}
.co2-card::before{content:'';position:absolute;right:-16px;top:-16px;width:80px;height:80px;background:var(--green);opacity:.1;border-radius:50%;}
.co2-title{font-family:'Syne',sans-serif;font-weight:700;font-size:11px;color:var(--green);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
.co2-num{font-family:'Syne',sans-serif;font-weight:800;font-size:26px;color:white;}
.co2-sub{font-size:11px;color:rgba(255,255,255,.4);margin-top:2px;}
.co2-bar{height:5px;background:rgba(255,255,255,.1);border-radius:3px;overflow:hidden;margin-top:12px;}
.co2-bar-fill{height:100%;background:var(--green);border-radius:3px;transition:width 1s ease;}
.co2-ml{font-size:10px;color:rgba(255,255,255,.3);margin-top:4px;}

.ride-card{background:var(--card);border-radius:16px;padding:14px;box-shadow:0 2px 8px rgba(0,48,135,.06);display:flex;flex-direction:column;gap:10px;transition:box-shadow .2s;}
.ride-card:hover{box-shadow:0 4px 18px rgba(0,48,135,.1);}
.ride-card.nr{border:2px solid var(--accent);}
.rh{display:flex;align-items:center;gap:8px;}
.rav{width:36px;height:36px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.rav svg{width:18px;height:18px;fill:white;}
.rname{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:var(--text);}
.rmeta{font-size:11px;color:var(--muted);}
.rbadge{margin-left:auto;background:var(--blue);color:white;font-size:11px;font-weight:700;padding:3px 9px;border-radius:18px;font-family:'Syne',sans-serif;white-space:nowrap;}
.rbadge.new{background:var(--gold);color:var(--blue);}
.rline{display:flex;flex-direction:column;gap:5px;padding:9px 12px;background:var(--bg);border-radius:10px;}
.rp{display:flex;align-items:center;gap:8px;}
.rdot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.rdot.fr{background:var(--accent);}
.rdot.to{background:var(--red);}
.rdash{width:9px;height:14px;display:flex;flex-direction:column;align-items:center;gap:2px;}
.rdash span{width:2px;height:4px;background:var(--border);display:block;border-radius:1px;}
.rlbl{font-size:12px;color:var(--text);font-weight:500;}
.rf{display:flex;align-items:center;justify-content:space-between;gap:8px;}
.chips{display:flex;gap:5px;flex-wrap:wrap;}
.chip{background:var(--bg);border-radius:18px;padding:4px 9px;font-size:10px;color:var(--muted);font-weight:500;display:flex;align-items:center;gap:3px;}
.chip svg{width:11px;height:11px;stroke:var(--muted);fill:none;stroke-width:2;}
.bbtn{background:var(--blue);color:white;border:none;border-radius:9px;padding:7px 14px;font-family:'Syne',sans-serif;font-weight:700;font-size:11px;cursor:pointer;transition:background .2s,transform .15s;white-space:nowrap;}
.bbtn:hover{background:var(--blue2);}

.sec-title{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;color:var(--text);}

.fg2{display:flex;flex-direction:column;gap:5px;margin-bottom:12px;}
.fl2{font-family:'Syne',sans-serif;font-weight:700;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;}
.fi2{background:var(--bg);border:2px solid var(--border);border-radius:11px;padding:11px 13px;font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;color:var(--text);outline:none;transition:border-color .2s;width:100%;}
.fi2:focus{border-color:var(--blue3);}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.sbtn{background:var(--blue);color:white;border:none;border-radius:11px;padding:13px;font-family:'Syne',sans-serif;font-weight:800;font-size:14px;cursor:pointer;width:100%;transition:background .2s;}
.sbtn:hover{background:var(--blue2);}
.phint{background:#e8f4fd;border:1.5px solid var(--blue3);border-radius:9px;padding:9px 13px;font-size:12px;color:var(--blue2);font-weight:600;display:flex;align-items:center;gap:7px;margin-bottom:4px;}

/* MAP */
.map-wrap{height:220px;background:#c8dfc4;border-radius:16px;position:relative;overflow:hidden;}
.mr-h{position:absolute;background:white;opacity:.7;height:7px;left:0;right:0;border-radius:3px;}
.mr-v{position:absolute;background:white;opacity:.7;width:7px;top:0;bottom:0;border-radius:3px;}
.mb{position:absolute;background:#b0caa8;border-radius:3px;}
.crdot{position:absolute;width:24px;height:24px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 3px 10px rgba(26,188,156,.5);animation:mcar 6s linear infinite,mpulse 2s ease-in-out infinite;}
.crdot svg{width:13px;height:13px;fill:white;}
@keyframes mcar{0%{left:14%;top:57%;}20%{left:27%;top:51%;}40%{left:44%;top:41%;}60%{left:59%;top:47%;}80%{left:71%;top:37%;}100%{left:14%;top:57%;}}
@keyframes mpulse{0%,100%{box-shadow:0 3px 10px rgba(26,188,156,.5);}50%{box-shadow:0 3px 20px rgba(26,188,156,.8);}}
.mmk{position:absolute;width:16px;height:16px;border-radius:50%;border:2.5px solid white;box-shadow:0 2px 6px rgba(0,0,0,.3);}
.mmk.a{background:var(--accent);top:57%;left:14%;}
.mmk.b{background:var(--red);top:37%;left:71%;}
.mbdg{position:absolute;border-radius:7px;padding:4px 9px;font-family:'Syne',sans-serif;font-size:10px;font-weight:700;}
.mbdg.di{bottom:8px;left:8px;background:rgba(0,48,135,.85);color:white;}
.mbdg.tm{bottom:8px;right:8px;background:var(--accent);color:white;}
.prog-bar{height:5px;background:var(--border);border-radius:3px;overflow:hidden;}
.prog-fill{height:100%;background:var(--accent);border-radius:3px;animation:pbar 6s linear infinite;}
@keyframes pbar{0%{width:15%;}100%{width:85%;}}

/* PROFILE */
.prof-hero{background:var(--blue);border-radius:18px;padding:22px;display:flex;align-items:center;gap:18px;position:relative;overflow:hidden;}
.prof-hero::before{content:'';position:absolute;right:-16px;top:-16px;width:90px;height:90px;background:var(--accent);opacity:.1;border-radius:50%;}
.prof-av{width:68px;height:68px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;border:3px solid rgba(255,255,255,.2);flex-shrink:0;}
.prof-av svg{width:36px;height:36px;fill:white;}
.prof-name{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;color:white;}
.prof-tag{font-size:12px;color:rgba(255,255,255,.5);}
.prof-email{font-size:11px;color:rgba(255,255,255,.3);margin-top:2px;}
.prof-pills{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;}
.prof-pill{background:rgba(255,255,255,.1);border-radius:8px;padding:5px 11px;text-align:center;}
.pp-num{font-family:'Syne',sans-serif;font-weight:800;font-size:16px;color:white;}
.pp-lbl{font-size:9px;color:rgba(255,255,255,.45);}

.info-tbl{width:100%;border-collapse:collapse;}
.info-tbl tr{border-bottom:1px solid var(--border);}
.info-tbl tr:last-child{border-bottom:none;}
.info-tbl td{padding:9px 0;font-size:13px;}
.info-tbl td:first-child{color:var(--muted);font-weight:500;width:38%;}
.info-tbl td:last-child{color:var(--text);font-weight:600;}

.ei{background:var(--bg);border:1.5px solid var(--border);border-radius:8px;padding:6px 10px;font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;color:var(--text);width:100%;outline:none;}
.ei:focus{border-color:var(--blue3);}
.savebtn{background:var(--blue);color:white;border:none;border-radius:9px;padding:9px 18px;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;cursor:pointer;}
.canbtn{background:var(--border);color:var(--muted);border:none;border-radius:9px;padding:9px 18px;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;cursor:pointer;}

.th-row{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);}
.th-row:last-child{border-bottom:none;}
.th-route{font-size:13px;font-weight:600;}
.th-date{font-size:11px;color:var(--muted);}
.th-price{font-family:'Syne',sans-serif;font-weight:800;font-size:13px;color:var(--blue);}
.th-co2{font-size:11px;color:var(--green);font-weight:600;}

/* MODAL */
.modwrap{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:400;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .3s;}
.modwrap.open{opacity:1;pointer-events:all;}
.modbox{background:var(--bg);border-radius:22px 22px 0 0;width:100%;max-width:520px;max-height:88vh;overflow-y:auto;padding:22px 18px;transform:translateY(100%);transition:transform .38s cubic-bezier(.34,1.2,.64,1);}
.modwrap.open .modbox{transform:translateY(0);}
.mhandle{width:38px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 18px;}
.mtitle{font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--text);margin-bottom:14px;}
.msr{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:12px;}
.ms{background:var(--card);border-radius:11px;padding:11px;text-align:center;}
.ms-num{font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--blue);}
.ms-lbl{font-size:10px;color:var(--muted);margin-top:2px;}
.cbtn{width:100%;background:var(--blue);color:white;border:none;border-radius:11px;padding:13px;font-family:'Syne',sans-serif;font-weight:800;font-size:14px;cursor:pointer;}
.cbtn:hover{background:var(--blue2);}

/* FILTER CHIPS */
.fchips{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px;}
.fc{background:var(--card);border:1.5px solid var(--border);border-radius:18px;padding:5px 13px;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;transition:all .2s;}
.fc.active{background:var(--blue);border-color:var(--blue);color:white;}

/* TOAST */
.toast{position:fixed;top:18px;right:18px;background:var(--blue);color:white;padding:12px 16px;border-radius:12px;font-family:'Syne',sans-serif;font-weight:700;font-size:13px;z-index:600;transform:translateY(-70px);opacity:0;transition:transform .38s cubic-bezier(.34,1.56,.64,1),opacity .28s;box-shadow:0 8px 24px rgba(0,48,135,.3);display:flex;align-items:center;gap:8px;max-width:300px;}
.toast.show{transform:translateY(0);opacity:1;}
.toast svg{width:16px;height:16px;fill:none;stroke:white;stroke-width:2.5;stroke-linecap:round;flex-shrink:0;}

.empty{text-align:center;padding:32px 16px;color:var(--muted);}
.empty svg{width:42px;height:42px;stroke:var(--border);fill:none;stroke-width:1.5;display:block;margin:0 auto 10px;}
.empty p{font-size:13px;}

/* ══ RESPONSIVE ══ */
@media(max-width:900px){
  .g4{grid-template-columns:1fr 1fr;}
}
@media(max-width:700px){
  body{overflow:auto;}
  #appWrap{flex-direction:column;}
  #sidebar{position:fixed;top:0;left:0;bottom:0;transform:translateX(-100%);box-shadow:4px 0 18px rgba(0,0,0,.3);}
  #sidebar.open{transform:translateX(0);}
  #sbo{display:block;}
  #topbar{padding:0 14px;height:50px;}
  .tb-menu{display:flex;}
  .tb-title{font-size:15px;}
  #pages{padding-bottom:60px;}
  .page{padding:14px 12px 72px;}
  #bnav{display:flex;}
  .g2,.g3,.g4{grid-template-columns:1fr 1fr;}
  .prof-hero{flex-direction:column;text-align:center;}
  .prof-pills{justify-content:center;}
  .toast{top:auto;bottom:72px;right:10px;left:10px;max-width:none;}
  .auth-hero{display:none;}
  .auth-form-panel{width:100%;}
}
@media(max-width:480px){
  .g3,.g4{grid-template-columns:1fr 1fr;}
  .frow{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- ═══════════ AUTH ═══════════ -->
<div id="authWrap">
  <!-- HERO PANEL -->
  <div class="auth-hero">
    <!-- UCU Shield -->
    <div class="ucu-shield-wrap">
      <!-- Inline UCU shield SVG (vector recreation of the logo) -->
      <svg class="ucu-shield" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="5" y="5" width="90" height="90" rx="28" stroke="white" stroke-width="5" fill="none"/>
        <!-- cross -->
        <line x1="50" y1="16" x2="50" y2="34" stroke="white" stroke-width="5" stroke-linecap="round"/>
        <line x1="41" y1="25" x2="59" y2="25" stroke="white" stroke-width="5" stroke-linecap="round"/>
        <!-- mountain -->
        <polyline points="22,62 50,38 78,62" stroke="white" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <!-- waves -->
        <line x1="20" y1="70" x2="80" y2="70" stroke="white" stroke-width="4" stroke-linecap="round"/>
        <line x1="24" y1="78" x2="76" y2="78" stroke="white" stroke-width="3.5" stroke-linecap="round"/>
        <line x1="30" y1="86" x2="70" y2="86" stroke="white" stroke-width="3" stroke-linecap="round"/>
      </svg>
      <div class="ucu-brand">
        <div class="ucu-brand-name">UCURide</div>
        <div class="ucu-brand-sub">Universidad Católica del Uruguay</div>
      </div>
    </div>

    <!-- Campus + Cars scene -->
    <svg class="campus-scene" viewBox="0 0 520 300" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Sky gradient bg -->
      <rect width="520" height="300" fill="#002568" rx="16"/>
      <!-- Stars -->
      <circle cx="40" cy="20" r="1.2" fill="white" opacity=".5"/>
      <circle cx="120" cy="35" r="1" fill="white" opacity=".4"/>
      <circle cx="200" cy="15" r="1.5" fill="white" opacity=".6"/>
      <circle cx="320" cy="28" r="1" fill="white" opacity=".4"/>
      <circle cx="450" cy="18" r="1.2" fill="white" opacity=".5"/>
      <circle cx="490" cy="42" r="1" fill="white" opacity=".3"/>

      <!-- Ground -->
      <rect x="0" y="220" width="520" height="80" fill="#1a4a28"/>
      <!-- Road -->
      <rect x="0" y="235" width="520" height="40" fill="#2c3e50"/>
      <!-- Road dashes -->
      <rect x="30" y="253" width="40" height="5" rx="2" fill="white" opacity=".4"/>
      <rect x="110" y="253" width="40" height="5" rx="2" fill="white" opacity=".4"/>
      <rect x="190" y="253" width="40" height="5" rx="2" fill="white" opacity=".4"/>
      <rect x="270" y="253" width="40" height="5" rx="2" fill="white" opacity=".4"/>
      <rect x="350" y="253" width="40" height="5" rx="2" fill="white" opacity=".4"/>
      <rect x="430" y="253" width="40" height="5" rx="2" fill="white" opacity=".4"/>

      <!-- CAMPUS BUILDING CENTER -->
      <!-- Main building body -->
      <rect x="175" y="100" width="170" height="130" fill="#1a3a6b" rx="4"/>
      <!-- Roof / pediment -->
      <polygon points="165,100 260,55 355,100" fill="#14326a"/>
      <!-- Cross on top -->
      <line x1="260" y1="40" x2="260" y2="62" stroke="white" stroke-width="3.5" stroke-linecap="round"/>
      <line x1="252" y1="49" x2="268" y2="49" stroke="white" stroke-width="3.5" stroke-linecap="round"/>
      <!-- Columns -->
      <rect x="195" y="130" width="10" height="100" fill="#14306a" rx="3"/>
      <rect x="220" y="130" width="10" height="100" fill="#14306a" rx="3"/>
      <rect x="293" y="130" width="10" height="100" fill="#14306a" rx="3"/>
      <rect x="315" y="130" width="10" height="100" fill="#14306a" rx="3"/>
      <!-- Windows -->
      <rect x="241" y="115" width="22" height="26" rx="11" fill="#f0c040" opacity=".7"/>
      <!-- Door -->
      <rect x="241" y="185" width="38" height="45" rx="3" fill="#0d2355"/>
      <circle cx="255" cy="210" r="3" fill="white" opacity=".4"/>
      <!-- Side wings -->
      <rect x="100" y="145" width="80" height="85" fill="#173465" rx="3"/>
      <rect x="340" y="145" width="80" height="85" fill="#173465" rx="3"/>
      <!-- Wing windows -->
      <rect x="115" y="158" width="18" height="18" rx="3" fill="#f0c040" opacity=".5"/>
      <rect x="148" y="158" width="18" height="18" rx="3" fill="#f0c040" opacity=".5"/>
      <rect x="355" y="158" width="18" height="18" rx="3" fill="#f0c040" opacity=".5"/>
      <rect x="388" y="158" width="18" height="18" rx="3" fill="#f0c040" opacity=".5"/>
      <!-- Lamp posts -->
      <rect x="152" y="195" width="4" height="40" fill="#8eabc8"/>
      <ellipse cx="154" cy="194" rx="8" ry="4" fill="#f0c040" opacity=".6"/>
      <rect x="362" y="195" width="4" height="40" fill="#8eabc8"/>
      <ellipse cx="364" cy="194" rx="8" ry="4" fill="#f0c040" opacity=".6"/>
      <!-- Trees -->
      <rect x="60" y="210" width="6" height="25" fill="#5d4037"/>
      <ellipse cx="63" cy="205" rx="18" ry="22" fill="#1b5e20"/>
      <ellipse cx="63" cy="200" rx="12" ry="15" fill="#2e7d32"/>
      <rect x="450" y="210" width="6" height="25" fill="#5d4037"/>
      <ellipse cx="453" cy="205" rx="18" ry="22" fill="#1b5e20"/>
      <ellipse cx="453" cy="200" rx="12" ry="15" fill="#2e7d32"/>

      <!-- STUDENTS walking -->
      <!-- Student 1 (left) -->
      <circle cx="88" cy="228" r="7" fill="#ffd180"/>
      <rect x="83" y="236" width="10" height="16" rx="3" fill="#1a5276"/>
      <line x1="83" y1="242" x2="77" y2="252" stroke="#ffd180" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="93" y1="242" x2="99" y2="252" stroke="#ffd180" stroke-width="2.5" stroke-linecap="round"/>
      <!-- Backpack -->
      <rect x="92" y="237" width="7" height="10" rx="2" fill="#e53935" opacity=".8"/>
      <!-- Student 2 (right) -->
      <circle cx="432" cy="228" r="7" fill="#ffccbc"/>
      <rect x="427" y="236" width="10" height="16" rx="3" fill="#6a1b9a"/>
      <line x1="427" y1="242" x2="421" y2="252" stroke="#ffccbc" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="437" y1="242" x2="443" y2="252" stroke="#ffccbc" stroke-width="2.5" stroke-linecap="round"/>
      <rect x="420" y="237" width="7" height="10" rx="2" fill="#ff7043" opacity=".8"/>

      <!-- CAR LEFT (going right) -->
      <!-- Body -->
      <rect x="10" y="240" width="88" height="28" rx="7" fill="#1e88e5"/>
      <!-- Cabin -->
      <rect x="22" y="229" width="58" height="16" rx="5" fill="#1565c0"/>
      <!-- Windows -->
      <rect x="26" y="231" width="22" height="12" rx="3" fill="#b3e5fc" opacity=".8"/>
      <rect x="52" y="231" width="22" height="12" rx="3" fill="#b3e5fc" opacity=".8"/>
      <!-- Wheels -->
      <circle cx="28" cy="270" r="9" fill="#212121"/>
      <circle cx="28" cy="270" r="4" fill="#616161"/>
      <circle cx="80" cy="270" r="9" fill="#212121"/>
      <circle cx="80" cy="270" r="4" fill="#616161"/>
      <!-- Headlights -->
      <rect x="96" y="246" width="6" height="6" rx="2" fill="#fff176"/>
      <!-- UCURide sticker -->
      <rect x="30" y="248" width="44" height="12" rx="3" fill="white" opacity=".15"/>
      <text x="34" y="257" font-family="sans-serif" font-size="7" font-weight="bold" fill="white" opacity=".8">UCURide</text>

      <!-- CAR RIGHT (going left) -->
      <rect x="422" y="240" width="88" height="28" rx="7" fill="#e53935"/>
      <rect x="440" y="229" width="58" height="16" rx="5" fill="#c62828"/>
      <rect x="444" y="231" width="22" height="12" rx="3" fill="#ffcdd2" opacity=".8"/>
      <rect x="470" y="231" width="22" height="12" rx="3" fill="#ffcdd2" opacity=".8"/>
      <circle cx="440" cy="270" r="9" fill="#212121"/>
      <circle cx="440" cy="270" r="4" fill="#616161"/>
      <circle cx="492" cy="270" r="9" fill="#212121"/>
      <circle cx="492" cy="270" r="4" fill="#616161"/>
      <rect x="418" y="246" width="6" height="6" rx="2" fill="#fff176"/>
      <rect x="446" y="248" width="44" height="12" rx="3" fill="white" opacity=".15"/>
      <text x="450" y="257" font-family="sans-serif" font-size="7" font-weight="bold" fill="white" opacity=".8">UCURide</text>
    </svg>

    <h1 class="auth-hero-title">Compartí el viaje,<br/>reducí el <span>impacto</span></h1>
    <p class="auth-hero-sub">La plataforma de carpooling oficial de la UCU · Montevideo</p>

    <!-- Parking CTA -->
    <div style="margin-top:18px;background:rgba(26,188,156,.15);border:1px solid rgba(26,188,156,.35);border-radius:14px;padding:12px 16px;max-width:400px;width:100%;position:relative;z-index:1;">
      <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:13px;color:var(--accent);margin-bottom:4px;">🅿️ Compartí tu viaje y obtené descuentos exclusivos en estacionamiento</div>
      <div style="font-size:11px;color:rgba(255,255,255,.55);line-height:1.5;">2 personas → <b style="color:white;">20% OFF</b> · 3 personas → <b style="color:white;">40% OFF</b> · 4 personas → <b style="color:white;">60% OFF</b> · 5+ → <b style="color:var(--accent);">PARKING GRATIS</b></div>
    </div>

    <!-- Benefits grid -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;max-width:400px;width:100%;margin-top:14px;position:relative;z-index:1;">
      <div style="background:rgba(255,255,255,.07);border-radius:12px;padding:12px 14px;display:flex;align-items:center;gap:10px;">
        <span style="font-size:20px;">⛽</span>
        <div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:12px;color:white;">Ahorro de combustible</div><div style="font-size:10px;color:rgba(255,255,255,.4);">Dividís el costo real</div></div>
      </div>
      <div style="background:rgba(255,255,255,.07);border-radius:12px;padding:12px 14px;display:flex;align-items:center;gap:10px;">
        <span style="font-size:20px;">🌿</span>
        <div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:12px;color:white;">Menos emisiones</div><div style="font-size:10px;color:rgba(255,255,255,.4);">~0.18 kg CO₂/km evitado</div></div>
      </div>
      <div style="background:rgba(255,255,255,.07);border-radius:12px;padding:12px 14px;display:flex;align-items:center;gap:10px;">
        <span style="font-size:20px;">🅿️</span>
        <div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:12px;color:white;">Parking con descuento</div><div style="font-size:10px;color:rgba(255,255,255,.4);">Hasta 100% OFF</div></div>
      </div>
      <div style="background:rgba(255,255,255,.07);border-radius:12px;padding:12px 14px;display:flex;align-items:center;gap:10px;">
        <span style="font-size:20px;">🎓</span>
        <div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:12px;color:white;">Conocer compañeros</div><div style="font-size:10px;color:rgba(255,255,255,.4);">Red UCU activa</div></div>
      </div>
    </div>
  </div>

  <!-- FORM PANEL -->
  <div class="auth-form-panel">
    <div class="auth-form-logo">
      <div class="auth-form-logo-icon"><svg viewBox="0 0 24 24"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg></div>
      <div class="auth-form-logo-text">UCU<em>Ride</em></div>
    </div>

    <div class="auth-tab-row">
      <div class="auth-tab active" id="tabLogin" onclick="showTab('login')">Iniciar sesión</div>
      <div class="auth-tab" id="tabReg" onclick="showTab('reg')">Registrarse</div>
    </div>

    <!-- LOGIN -->
    <div id="formLogin">
      <div class="auth-title">Bienvenido 👋</div>
      <div class="auth-sub">Ingresá con tu cuenta UCURide</div>
      <div class="fg"><label class="fl">Correo electrónico</label><input class="fi" id="lEmail" type="email" placeholder="tu@correo.com"/></div>
      <div class="fg"><label class="fl">Contraseña</label><input class="fi" id="lPass" type="password" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"/></div>
      <button class="abtn" onclick="doLogin()">Iniciar sesión</button>
      <div class="alink">¿No tenés cuenta? <span onclick="showTab('reg')">Registrate gratis</span></div>
    </div>

    <!-- REGISTER -->
    <div id="formReg" style="display:none;">
      <div class="auth-title">Crear cuenta 🎓</div>
      <div class="auth-sub">Únete a la comunidad UCURide</div>
      <div class="fg"><label class="fl">Nombre completo</label><input class="fi" id="rName" type="text" placeholder="Ej: Sofía Torres"/></div>
      <div class="fg"><label class="fl">Correo electrónico</label><input class="fi" id="rEmail" type="email" placeholder="tu@correo.com"/></div>
      <div class="fg"><label class="fl">Carrera / Facultad</label><input class="fi" id="rCareer" type="text" placeholder="Ej: Derecho 3er año"/></div>
      <div class="fg"><label class="fl">Vehículo (opcional)</label><input class="fi" id="rCar" type="text" placeholder="Ej: VW Gol Gris"/></div>
      <div class="fg"><label class="fl">Contraseña</label><input class="fi" id="rPass" type="password" placeholder="Mínimo 6 caracteres"/></div>
      <button class="abtn" onclick="doRegister()">Crear cuenta</button>
      <div class="alink">¿Ya tenés cuenta? <span onclick="showTab('login')">Iniciar sesión</span></div>
    </div>
  </div>
</div>

<!-- ═══════════ APP ═══════════ -->
<div id="appWrap">
  <div id="sbo" onclick="closeSB()"></div>
  <!-- SIDEBAR -->
  <nav id="sidebar">
    <div class="sb-logo">
      <div class="sb-logo-icon"><svg viewBox="0 0 24 24"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg></div>
      <div><div class="sb-logo-text">UCU<em>Ride</em></div><span class="sb-logo-sub">Universidad Católica del Uruguay</span></div>
    </div>
    <div class="sb-user" onclick="nav('profile')">
      <div class="sb-user-av"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
      <div style="overflow:hidden;"><div class="sb-user-name" id="sbName">—</div><div class="sb-user-role" id="sbRole">—</div></div>
    </div>
    <div class="sb-nav">
      <button class="sb-item active" data-p="home" onclick="nav('home')"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg><span>Inicio</span></button>
      <button class="sb-item" data-p="search" onclick="nav('search')"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><span>Buscar viajes</span></button>
      <button class="sb-item" data-p="offer" onclick="nav('offer')"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg><span>Ofrecer viaje</span></button>
      <button class="sb-item" data-p="track" onclick="nav('track')"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Seguimiento</span></button>
      <button class="sb-item" data-p="profile" onclick="nav('profile')"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg><span>Mi perfil</span></button>
      <button class="sb-item" data-p="benefits" onclick="nav('benefits')"><svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><span>Beneficios</span></button>
    </div>
    <div class="sb-footer">
      <button class="sb-logout" onclick="doLogout()"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Cerrar sesión</button>
    </div>
  </nav>

  <!-- MAIN -->
  <div id="appMain">
    <div id="topbar">
      <div style="display:flex;align-items:center;gap:10px;">
        <button class="tb-menu" onclick="openSB()"><svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
        <div class="tb-title">
          <svg width="20" height="20" viewBox="0 0 100 100" fill="none"><rect x="5" y="5" width="90" height="90" rx="28" stroke="var(--blue)" stroke-width="7" fill="none"/><line x1="50" y1="16" x2="50" y2="32" stroke="var(--blue)" stroke-width="6" stroke-linecap="round"/><line x1="42" y1="24" x2="58" y2="24" stroke="var(--blue)" stroke-width="6" stroke-linecap="round"/><polyline points="24,62 50,40 76,62" stroke="var(--blue)" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/><line x1="22" y1="70" x2="78" y2="70" stroke="var(--blue)" stroke-width="5" stroke-linecap="round"/><line x1="26" y1="78" x2="74" y2="78" stroke="var(--blue)" stroke-width="4.5" stroke-linecap="round"/><line x1="32" y1="86" x2="68" y2="86" stroke="var(--blue)" stroke-width="4" stroke-linecap="round"/></svg>
          <span id="tbTitle">Inicio</span>
        </div>
      </div>
      <div class="tb-right">
        <span class="tb-date" id="tbDate"></span>
        <div class="tb-av" onclick="nav('profile')"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
      </div>
    </div>

    <div id="pages">

      <!-- HOME -->
      <div class="page active" id="p-home">
        <div class="col">
          <div class="hero-banner">
            <div class="hb-text"><h2>Tu próximo viaje,<br/>a un clic de distancia</h2><p>Conectá con compañeros de ruta UCU</p></div>
            <div class="hb-icon"><svg viewBox="0 0 24 24"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg></div>
          </div>
          <div class="g4">
            <div class="stat-card"><div class="sc-icon" style="background:#e8eef8;"><svg viewBox="0 0 24 24" style="stroke:var(--blue);fill:none;stroke-width:2;stroke-linecap:round;"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div><div class="sc-num" id="hTrips">0</div><div class="sc-lbl">Mis viajes</div></div>
            <div class="stat-card"><div class="sc-icon" style="background:#e8f8f2;"><svg viewBox="0 0 24 24" style="stroke:var(--green);fill:none;stroke-width:2;stroke-linecap:round;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div><div class="sc-num" style="color:var(--green);" id="hCO2">0</div><div class="sc-lbl">kg CO₂ evitado</div></div>
            <div class="stat-card"><div class="sc-icon" style="background:#fef9e7;"><svg viewBox="0 0 24 24" style="stroke:#c9a000;fill:none;stroke-width:2;stroke-linecap:round;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div><div class="sc-num" style="color:#c9a000;" id="hStars">5.0</div><div class="sc-lbl">Calificación</div></div>
            <div class="stat-card"><div class="sc-icon" style="background:#fef0ef;"><svg viewBox="0 0 24 24" style="stroke:var(--red);fill:none;stroke-width:2;stroke-linecap:round;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div><div class="sc-num" style="color:var(--red);" id="hAvail">3</div><div class="sc-lbl">Viajes disponibles</div></div>
          </div>
          <div class="co2-card">
            <div class="co2-title">🌿 CO₂ evitado acumulado — mi impacto ambiental</div>
            <div style="display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;">
              <div><div class="co2-num" id="hCO2Num">0.0 kg</div><div class="co2-sub" id="hCO2Trees">= 0.0 árboles plantados</div></div>
              <div style="flex:1;min-width:140px;"><div class="co2-bar"><div class="co2-bar-fill" id="hCO2Bar" style="width:0%"></div></div><div class="co2-ml" id="hCO2ML">Próxima meta: 10 kg</div></div>
            </div>
          </div>
          <div class="sec-title">Viajes recientes</div>
          <div class="col" id="hRides"></div>
        </div>
      </div>

      <!-- SEARCH -->
      <div class="page" id="p-search">
        <div class="col">
          <div class="hero-banner" style="padding:16px 20px;">
            <div class="hb-text"><h2 style="font-size:clamp(14px,1.4vw,18px);">Buscar viajes disponibles</h2><p>Rutas activas hacia la UCU</p></div>
            <div class="hb-icon" style="width:44px;height:44px;"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
          </div>
          <input class="fi2" id="sInput" type="text" placeholder="Buscar por zona, destino o conductor..." oninput="renderSearch()" style="background:var(--card);"/>
          <div class="fchips">
            <div class="fc active" onclick="setF('todos',this)">Todos</div>
            <div class="fc" onclick="setF('manana',this)">Mañana</div>
            <div class="fc" onclick="setF('tarde',this)">Tarde</div>
            <div class="fc" onclick="setF('noche',this)">Noche</div>
          </div>
          <div class="col" id="sRides"></div>
        </div>
      </div>

      <!-- OFFER -->
      <div class="page" id="p-offer">
        <div style="max-width:580px;" class="col">
          <div class="sec-title" style="font-size:18px;">Publicar viaje</div>
          <div class="card">
            <div class="card-title">Recorrido</div>
            <div class="fg2"><label class="fl2">Desde</label><input class="fi2" id="oFrom" type="text" placeholder="Ej: Pocitos, Carrasco, Centro..." oninput="estPrice()"/></div>
            <div class="fg2"><label class="fl2">Hasta</label><input class="fi2" id="oTo" type="text" placeholder="Ej: UCU Montevideo..." oninput="estPrice()"/></div>
            <div class="frow">
              <div class="fg2"><label class="fl2">Fecha</label><input class="fi2" id="oDate" type="date"/></div>
              <div class="fg2"><label class="fl2">Hora</label><input class="fi2" id="oTime" type="time"/></div>
            </div>
          </div>
          <div class="card">
            <div class="card-title">Vehículo</div>
            <div class="fg2"><label class="fl2">Asientos disponibles</label><input class="fi2" id="oSeats" type="number" min="1" max="5" placeholder="3" oninput="estPrice()"/></div>
            <div class="fg2"><label class="fl2">Consumo del vehículo (L/100km)</label>
              <select class="fi2" id="oConsume" onchange="estPrice()">
                <option value="7">7 L/100km — Económico (ej. Fiat 500, VW Polo)</option>
                <option value="9" selected>9 L/100km — Mediano (ej. VW Gol, Sandero)</option>
                <option value="11">11 L/100km — Familiar (ej. Suran, Spin)</option>
                <option value="13">13 L/100km — SUV (ej. Duster, Tracker)</option>
                <option value="16">16 L/100km — Camioneta/4x4</option>
              </select>
            </div>
            <!-- Precio calculado automáticamente -->
            <div id="oHint" style="display:none;background:linear-gradient(135deg,#e8f4fd,#f0f8ff);border:1.5px solid var(--blue3);border-radius:12px;padding:14px 16px;">
              <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:12px;color:var(--blue);margin-bottom:10px;text-transform:uppercase;letter-spacing:.5px;">💡 Precio calculado automáticamente</div>
              <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:10px;">
                <div style="background:white;border-radius:9px;padding:10px;text-align:center;"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--blue);" id="hintPrice">—</div><div style="font-size:10px;color:var(--muted);">UYU/persona</div></div>
                <div style="background:white;border-radius:9px;padding:10px;text-align:center;"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--blue2);" id="hintKm">—</div><div style="font-size:10px;color:var(--muted);">km</div></div>
                <div style="background:white;border-radius:9px;padding:10px;text-align:center;"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--green);" id="hintCO2">—</div><div style="font-size:10px;color:var(--muted);">kg CO₂</div></div>
              </div>
              <div id="hintFormula" style="font-size:11px;color:var(--muted);line-height:1.5;"></div>
              <div id="hintParking" style="margin-top:8px;background:rgba(0,48,135,.06);border-radius:8px;padding:8px 10px;font-size:11px;color:var(--blue2);font-weight:600;"></div>
            </div>
            <div class="fg2"><label class="fl2">Vehículo</label><input class="fi2" id="oCar" type="text" placeholder="Ej: VW Gol Gris · SBD 1234"/></div>
            <div class="fg2"><label class="fl2">Nota (opcional)</label><input class="fi2" id="oNote" type="text" placeholder="Ej: Paso por Tres Cruces..."/></div>
          </div>
          <button class="sbtn" onclick="publishRide()">🚗 Publicar viaje</button>
        </div>
      </div>

      <!-- TRACK -->
      <div class="page" id="p-track">
        <div class="col" style="max-width:760px;">
          <!-- REAL MAP -->
          <div id="leafletMap" style="height:300px;border-radius:16px;overflow:hidden;z-index:1;"></div>
          <div class="card">
            <div style="display:flex;align-items:center;gap:14px;">
              <div style="width:50px;height:50px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg viewBox="0 0 24 24" width="26" height="26" fill="white"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
              <div style="flex:1;"><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:15px;" id="tDriver">—</div><div style="font-size:12px;color:var(--muted);" id="tCar">—</div></div>
              <div style="text-align:center;"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:26px;color:var(--accent);" id="tETA">—</div><div style="font-size:10px;color:var(--muted);">min est.</div></div>
            </div>
            <div style="margin-top:12px;"><div class="prog-bar"><div class="prog-fill"></div></div>
              <div style="display:flex;justify-content:space-between;margin-top:5px;"><span style="font-size:11px;color:var(--muted);" id="tFrom">—</span><span style="font-size:11px;color:var(--muted);" id="tTo">—</span></div>
            </div>
            <div style="display:flex;gap:10px;margin-top:10px;flex-wrap:wrap;">
              <div style="flex:1;background:var(--bg);border-radius:9px;padding:9px 13px;display:flex;justify-content:space-between;align-items:center;"><span style="font-size:11px;color:var(--muted);">💵 Precio</span><span style="font-family:'Syne',sans-serif;font-weight:800;font-size:13px;color:var(--blue);" id="tPrice">—</span></div>
              <div style="flex:1;background:var(--bg);border-radius:9px;padding:9px 13px;display:flex;justify-content:space-between;align-items:center;"><span style="font-size:11px;color:var(--muted);">📍 Distancia</span><span style="font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:var(--text);" id="tDistInfo">—</span></div>
            </div>
          </div>
          <div class="co2-card">
            <div class="co2-title">🌿 CO₂ evitado</div>
            <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;">
              <div><div class="co2-num" id="tCO2">—</div><div class="co2-sub">este viaje vs. ir solo</div></div>
              <div style="text-align:right;"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:20px;color:var(--green);" id="tTotalCO2">—</div><div style="font-size:10px;color:rgba(255,255,255,.4);">total acumulado</div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- PROFILE -->
      <div class="page" id="p-profile">
        <div class="col" style="max-width:700px;">
          <div class="prof-hero">
            <div class="prof-av"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
            <div style="position:relative;z-index:1;">
              <div class="prof-name" id="pName">—</div>
              <div class="prof-tag" id="pTag">—</div>
              <div class="prof-email" id="pEmail">—</div>
              <div class="prof-pills">
                <div class="prof-pill"><div class="pp-num" id="ppTrips">0</div><div class="pp-lbl">Viajes</div></div>
                <div class="prof-pill"><div class="pp-num" style="color:var(--accent);" id="ppCO2">0</div><div class="pp-lbl">kg CO₂</div></div>
                <div class="prof-pill"><div class="pp-num" style="color:var(--gold);" id="ppStars">5.0</div><div class="pp-lbl">⭐ Stars</div></div>
              </div>
            </div>
          </div>

          <div class="g2" style="align-items:start;">
            <!-- Account data -->
            <div class="card">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                <div class="card-title" style="margin:0;">Datos de la cuenta</div>
                <button id="editBtn" onclick="toggleEdit()" style="background:var(--blue);color:white;border:none;border-radius:8px;padding:6px 13px;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;cursor:pointer;">✏️ Editar</button>
              </div>
              <div id="pView">
                <table class="info-tbl">
                  <tr><td>Nombre</td><td id="iName">—</td></tr>
                  <tr><td>Correo</td><td id="iEmail">—</td></tr>
                  <tr><td>Carrera</td><td id="iCareer">—</td></tr>
                  <tr><td>Vehículo</td><td id="iCar">—</td></tr>
                  <tr><td>Miembro desde</td><td id="iSince">—</td></tr>
                </table>
              </div>
              <div id="pEdit" style="display:none;">
                <div class="fg2"><label class="fl2">Nombre</label><input class="ei" id="eName" type="text"/></div>
                <div class="fg2"><label class="fl2">Carrera</label><input class="ei" id="eCareer" type="text"/></div>
                <div class="fg2"><label class="fl2">Vehículo</label><input class="ei" id="eCar" type="text"/></div>
                <div class="fg2"><label class="fl2">Nueva contraseña</label><input class="ei" id="ePass" type="password" placeholder="Dejar vacío para no cambiar"/></div>
                <div style="display:flex;gap:8px;margin-top:8px;"><button class="savebtn" onclick="saveProfile()">Guardar</button><button class="canbtn" onclick="cancelEdit()">Cancelar</button></div>
              </div>
            </div>
            <!-- CO2 + published -->
            <div class="col">
              <div class="co2-card">
                <div class="co2-title">🌿 Impacto ambiental</div>
                <div class="co2-num" id="pCO2">0.0 kg</div>
                <div class="co2-sub" id="pTrees">= 0 árboles</div>
                <div class="co2-bar" style="margin-top:10px;"><div class="co2-bar-fill" id="pCO2Bar" style="width:0%"></div></div>
                <div class="co2-ml" id="pCO2ML">Meta: 10 kg</div>
              </div>
              <div class="card">
                <div class="card-title">Viajes que ofrecí</div>
                <div id="myPub"></div>
              </div>
            </div>
          </div>

          <!-- Trip history -->
          <div class="card">
            <div class="card-title">Historial de viajes</div>
            <div id="tripHist"></div>
          </div>
        </div>
      </div>

      <!-- BENEFITS -->
      <div class="page" id="p-benefits">
        <div class="col" style="max-width:780px;">
          <div class="hero-banner">
            <div class="hb-text"><h2>Beneficios de compartir el viaje</h2><p>Cada viaje compartido tiene impacto real · UCURide</p></div>
            <div class="hb-icon"><svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="white"/></svg></div>
          </div>

          <!-- 4 benefit cards -->
          <div class="g2">
            <div class="card" style="border-left:4px solid var(--accent);">
              <div style="font-size:32px;margin-bottom:10px;">⛽</div>
              <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--blue);margin-bottom:6px;">Ahorro de combustible</div>
              <div style="font-size:13px;color:var(--muted);line-height:1.6;">El costo del viaje se divide entre todos los pasajeros en base al precio real del combustible en Uruguay (nafta súper ~$87/L) y el consumo del vehículo. Si viajás con 3 personas, cada uno paga solo un tercio del gasto real.</div>
              <div style="margin-top:12px;background:var(--bg);border-radius:10px;padding:12px 14px;">
                <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:12px;color:var(--blue);margin-bottom:6px;">Ejemplo: Pocitos → UCU (8.2 km)</div>
                <div style="font-size:12px;color:var(--muted);">Solo: <b style="color:var(--text);">~63 UYU</b> · Con 2: <b style="color:var(--accent);">~32 UYU c/u</b> · Con 3: <b style="color:var(--accent);">~21 UYU c/u</b></div>
              </div>
            </div>
            <div class="card" style="border-left:4px solid var(--green);">
              <div style="font-size:32px;margin-bottom:10px;">🌿</div>
              <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--blue);margin-bottom:6px;">Menos emisiones de CO₂</div>
              <div style="font-size:13px;color:var(--muted);line-height:1.6;">Un auto promedio emite ~0.21 kg de CO₂ por km. Al compartir el viaje con otras personas, las emisiones por pasajero caen drásticamente. UCURide calcula el CO₂ evitado real por cada viaje compartido.</div>
              <div style="margin-top:12px;background:#062a1e;border-radius:10px;padding:12px 14px;">
                <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:12px;color:var(--green);margin-bottom:6px;">CO₂ evitado por viaje (8.2 km)</div>
                <div style="font-size:12px;color:rgba(255,255,255,.6);">2 personas: <b style="color:white;">~0.86 kg</b> · 3 personas: <b style="color:var(--green);">~1.37 kg</b> · 4 personas: <b style="color:var(--green);">~1.59 kg</b></div>
              </div>
            </div>
            <div class="card" style="border-left:4px solid var(--blue3);">
              <div style="font-size:32px;margin-bottom:10px;">🅿️</div>
              <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--blue);margin-bottom:6px;">Parking con descuento</div>
              <div style="font-size:13px;color:var(--muted);line-height:1.6;">Compartí tu viaje y obtené descuentos exclusivos en estacionamiento en los parkings adheridos a UCURide. Cuantas más personas traigas, mayor el descuento. ¡Con 5 o más, el parking es gratis!</div>
              <div style="margin-top:12px;display:flex;flex-direction:column;gap:6px;">
                <div style="display:flex;align-items:center;justify-content:space-between;background:var(--bg);border-radius:8px;padding:8px 12px;"><span style="font-size:12px;font-weight:600;">👥 2 personas</span><span style="font-family:'Syne',sans-serif;font-weight:800;font-size:13px;color:var(--blue3);">20% OFF</span></div>
                <div style="display:flex;align-items:center;justify-content:space-between;background:var(--bg);border-radius:8px;padding:8px 12px;"><span style="font-size:12px;font-weight:600;">👥 3 personas</span><span style="font-family:'Syne',sans-serif;font-weight:800;font-size:13px;color:var(--blue2);">40% OFF</span></div>
                <div style="display:flex;align-items:center;justify-content:space-between;background:var(--bg);border-radius:8px;padding:8px 12px;"><span style="font-size:12px;font-weight:600;">👥 4 personas</span><span style="font-family:'Syne',sans-serif;font-weight:800;font-size:13px;color:var(--blue);">60% OFF</span></div>
                <div style="display:flex;align-items:center;justify-content:space-between;background:var(--blue);border-radius:8px;padding:8px 12px;"><span style="font-size:12px;font-weight:700;color:white;">👥 5+ personas</span><span style="font-family:'Syne',sans-serif;font-weight:800;font-size:13px;color:var(--accent);">🎉 PARKING GRATIS</span></div>
              </div>
            </div>
            <div class="card" style="border-left:4px solid var(--gold);">
              <div style="font-size:32px;margin-bottom:10px;">🎓</div>
              <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:17px;color:var(--blue);margin-bottom:6px;">Conocer compañeros UCU</div>
              <div style="font-size:13px;color:var(--muted);line-height:1.6;">UCURide conecta exclusivamente a estudiantes, docentes y administrativos de la Universidad Católica del Uruguay. Viajá con gente de tu comunidad, ampliá tu red y hacé el trayecto más ameno.</div>
              <div style="margin-top:12px;background:var(--bg);border-radius:10px;padding:12px 14px;display:flex;gap:12px;align-items:center;">
                <div style="font-size:24px;">🤝</div>
                <div style="font-size:12px;color:var(--muted);line-height:1.5;">Todos los usuarios están verificados con correo institucional UCU.</div>
              </div>
            </div>
          </div>

          <!-- Impact summary bar -->
          <div style="background:var(--blue);border-radius:18px;padding:22px 24px;">
            <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:16px;color:white;margin-bottom:16px;text-align:center;">📊 Tu impacto acumulado en UCURide</div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
              <div style="background:rgba(255,255,255,.1);border-radius:12px;padding:16px;text-align:center;"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:22px;color:white;" id="bTrips">0</div><div style="font-size:11px;color:rgba(255,255,255,.5);margin-top:3px;">Viajes compartidos</div></div>
              <div style="background:rgba(255,255,255,.1);border-radius:12px;padding:16px;text-align:center;"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:22px;color:var(--accent);" id="bCO2">0 kg</div><div style="font-size:11px;color:rgba(255,255,255,.5);margin-top:3px;">CO₂ evitado</div></div>
              <div style="background:rgba(255,255,255,.1);border-radius:12px;padding:16px;text-align:center;"><div style="font-family:'Syne',sans-serif;font-weight:800;font-size:22px;color:var(--gold);" id="bParking">0%</div><div style="font-size:11px;color:rgba(255,255,255,.5);margin-top:3px;">Descuento parking actual</div></div>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /pages -->

    <!-- BOTTOM NAV (mobile) -->
    <div id="bnav">
      <button class="bn active" data-p="home" onclick="nav('home')"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg><span>Inicio</span></button>
      <button class="bn" data-p="search" onclick="nav('search')"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><span>Buscar</span></button>
      <button class="bn" data-p="offer" onclick="nav('offer')"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg><span>Ofrecer</span></button>
      <button class="bn" data-p="track" onclick="nav('track')"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Seguir</span></button>
      <button class="bn" data-p="profile" onclick="nav('profile')"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg><span>Perfil</span></button>
    </div>
  </div>
</div>

<!-- TRIP MODAL -->
<div class="modwrap" id="modWrap" onclick="closeMod(event)">
  <div class="modbox" style="max-width:600px;padding:0;border-radius:22px 22px 0 0;overflow:hidden;">
    <!-- Handle -->
    <div style="padding:14px 18px 0;"><div class="mhandle"></div></div>

    <!-- Header ruta -->
    <div style="padding:0 18px 14px;display:flex;align-items:center;justify-content:space-between;">
      <div>
        <div class="mtitle" id="modTitle" style="margin-bottom:2px;">Detalle del viaje</div>
        <div style="font-size:12px;color:var(--muted);" id="modDateHour">—</div>
      </div>
      <div style="background:var(--blue);color:white;font-family:'Syne',sans-serif;font-weight:800;font-size:16px;padding:8px 16px;border-radius:12px;" id="modPriceBig">— UYU</div>
    </div>

    <!-- Mapa Google Maps embed -->
    <div style="position:relative;height:200px;background:#e8edf2;margin-bottom:0;">
      <iframe id="modMapFrame"
        style="width:100%;height:100%;border:none;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        src="about:blank">
      </iframe>
      <!-- Chips sobre el mapa -->
      <div style="position:absolute;bottom:8px;left:8px;display:flex;gap:6px;">
        <div style="background:rgba(0,48,135,.9);color:white;border-radius:7px;padding:4px 10px;font-family:'Syne',sans-serif;font-size:11px;font-weight:700;" id="modDist">—</div>
        <div style="background:rgba(26,188,156,.9);color:white;border-radius:7px;padding:4px 10px;font-family:'Syne',sans-serif;font-size:11px;font-weight:700;" id="modTime">—</div>
      </div>
    </div>

    <!-- Stats row -->
    <div style="padding:12px 18px;">
      <div class="msr" style="margin-bottom:10px;">
        <div class="ms"><div class="ms-num" id="modPrice">—</div><div class="ms-lbl">UYU/persona</div></div>
        <div class="ms"><div class="ms-num" id="modKm">—</div><div class="ms-lbl">km</div></div>
        <div class="ms"><div class="ms-num" id="modMin">—</div><div class="ms-lbl">min est.</div></div>
      </div>

      <!-- CO2 -->
      <div style="background:#062a1e;border-radius:11px;padding:10px 13px;display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <span style="font-size:12px;color:var(--green);font-weight:600;">🌿 CO₂ evitado vs ir solo</span>
        <span style="font-family:'Syne',sans-serif;font-weight:800;font-size:15px;color:var(--green);" id="modCO2">—</span>
      </div>

      <!-- Conductor card -->
      <div style="background:var(--bg);border-radius:13px;padding:14px;margin-bottom:12px;">
        <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px;">🚗 Conductor y vehículo</div>
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;">
          <div style="width:46px;height:46px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="white"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div>
            <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:15px;" id="modDriver">—</div>
            <div style="font-size:12px;color:var(--muted);" id="modCar">—</div>
          </div>
          <div style="margin-left:auto;text-align:center;">
            <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:18px;color:var(--gold);">⭐ 5.0</div>
            <div style="font-size:10px;color:var(--muted);">calificación</div>
          </div>
        </div>
        <div style="display:flex;justify-content:space-between;padding-top:8px;border-top:1px solid var(--border);">
          <span style="font-size:12px;color:var(--muted);">Asientos disponibles</span>
          <span style="font-family:'Syne',sans-serif;font-weight:800;color:var(--blue);" id="modSeats">—</span>
        </div>
      </div>

      <!-- Chat / Consultas -->
      <div style="background:var(--bg);border-radius:13px;padding:14px;margin-bottom:14px;">
        <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px;">💬 Consultas al conductor</div>
        <div id="modChat" style="max-height:140px;overflow-y:auto;display:flex;flex-direction:column;gap:7px;margin-bottom:10px;">
          <div style="text-align:center;font-size:12px;color:var(--muted);padding:10px 0;">Sé el primero en preguntar algo al conductor</div>
        </div>
        <div style="display:flex;gap:8px;">
          <input id="modChatInput" class="fi2" type="text" placeholder="Escribí tu consulta..." style="flex:1;padding:9px 12px;font-size:13px;" onkeydown="if(event.key==='Enter')sendModChat()"/>
          <button onclick="sendModChat()" style="background:var(--blue);color:white;border:none;border-radius:10px;padding:9px 14px;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;cursor:pointer;white-space:nowrap;">Enviar</button>
        </div>
      </div>

      <!-- Botón reserva -->
      <button class="cbtn" onclick="confirmBook()">✓ Confirmar reserva</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg><span id="toastMsg"></span></div>

<script>
/* ═══════════════════════════
   CONSTANTES URUGUAY (reales)
   Nafta súper mayo 2026: ~87 UYU/L
   CO₂ por litro gasolina: 2.31 kg
   CO₂ evitado por km compartido:
     emisiones_auto - emisiones_divididas
═══════════════════════════ */
const FUEL_UYU = 87;    // UYU por litro nafta súper
const CO2_PER_L = 2.31; // kg CO₂ por litro quemado

// Consumo por tipo de auto (L/100km)
const CONSUME_DEFAULT = 9;

// Distancias reales Montevideo (km) via OSRM si online, sino tabla
const DISTS={
  'pocitos':{'ucu':8.2,'ucu montevideo':8.2,'centro':3.5,'carrasco':9.0,'punta carretas':2.0,'malvin':5.5,'tres cruces':5.2,'buceo':3.8,'goes':5.8,'la blanqueada':4.2,'parque batlle':4.0},
  'centro':{'ucu':5.5,'ucu montevideo':5.5,'pocitos':3.5,'carrasco':12.0,'punta carretas':4.2,'malvin':7.0,'tres cruces':2.5,'buceo':5.0,'goes':3.2,'la blanqueada':2.8,'parque batlle':3.5},
  'carrasco':{'ucu':14.5,'ucu montevideo':14.5,'centro':12.0,'pocitos':9.0,'punta carretas':8.5,'malvin':6.0,'tres cruces':14.0,'parque batlle':9.0},
  'punta carretas':{'ucu':6.8,'ucu montevideo':6.8,'pocitos':2.0,'centro':4.2,'carrasco':8.5,'malvin':4.0,'buceo':2.5},
  'malvin':{'ucu':9.5,'ucu montevideo':9.5,'centro':7.0,'pocitos':5.5,'tres cruces':9.0,'parque batlle':6.5},
  'tres cruces':{'ucu':3.5,'ucu montevideo':3.5,'centro':2.5,'pocitos':5.2,'carrasco':14.0,'la blanqueada':2.0},
  'buceo':{'ucu':7.0,'ucu montevideo':7.0,'pocitos':3.8,'centro':5.0,'punta carretas':2.5},
  'goes':{'ucu':4.8,'ucu montevideo':4.8,'centro':3.2,'tres cruces':3.8},
  'la blanqueada':{'ucu':3.5,'ucu montevideo':3.5,'centro':2.8,'pocitos':5.0,'tres cruces':2.0},
  'parque batlle':{'ucu':4.2,'ucu montevideo':4.2,'centro':3.5,'pocitos':4.0,'malvin':6.5,'carrasco':9.0},
  'aguada':{'ucu':4.0,'ucu montevideo':4.0,'centro':1.8,'tres cruces':2.8},
  'cordon':{'ucu':4.5,'ucu montevideo':4.5,'centro':1.5,'pocitos':3.8},
  'palermo':{'ucu':5.0,'ucu montevideo':5.0,'pocitos':2.8,'centro':2.5},
};

function gd(f,t){
  const fl=f.toLowerCase().trim(),tl=t.toLowerCase().trim();
  for(const k in DISTS){
    if(fl.includes(k)||k.split(' ').some(w=>w.length>3&&fl.includes(w))){
      for(const k2 in DISTS[k]){
        if(tl.includes(k2)||k2.split(' ').some(w=>w.length>3&&tl.includes(w)))return DISTS[k][k2];
      }
    }
  }
  // fallback: distancia basada en longitud de strings (8-14 km rango Mdeo)
  return 6 + ((fl.length * 3 + tl.length * 2) % 9);
}

/**
 * Calcula precio real por pasajero
 * precio = (distKm * consume/100 * FUEL_UYU) / asientos
 * Se redondea a múltiplo de 5
 */
function calcPrice(distKm, consumeL100, seats){
  const litros = distKm * consumeL100 / 100;
  const costoTotal = litros * FUEL_UYU;
  const porPersona = costoTotal / Math.max(1, seats);
  return Math.round(porPersona / 5) * 5;
}

/**
 * CO₂ evitado REAL (kg)
 * Un auto solo: distKm * consumeL100/100 * CO2_PER_L
 * Con N pasajeros: cada uno "causa" 1/N de esas emisiones
 * Ahorro vs ir solo en su propio auto: emision_auto - emision_compartida
 */
function calcCO2saved(distKm, consumeL100, seats){
  const emisionAuto = distKm * consumeL100 / 100 * CO2_PER_L; // emisión de 1 auto
  const emisionCompartida = emisionAuto / Math.max(1, seats);  // parte del pasajero
  // Si el pasajero hubiera ido solo en su propio auto, habría generado emisionAuto
  // Lo que ahorra = emisionAuto - emisionCompartida
  return Math.max(0, emisionAuto - emisionCompartida).toFixed(2);
}

function cd(d){ return Math.round(d / 22 * 60); } // ~22 km/h ciudad Mvdeo

/* Parking discount based on seats booked */
function parkingDiscount(seats){
  if(seats>=5) return {pct:100,label:'PARKING GRATIS 🎉'};
  if(seats>=4) return {pct:60,label:'60% OFF parking'};
  if(seats>=3) return {pct:40,label:'40% OFF parking'};
  if(seats>=2) return {pct:20,label:'20% OFF parking'};
  return {pct:0,label:''};
}

/* ═══════════════════════════
   FIREBASE — Base de datos compartida
   Todos los usuarios ven los mismos
   viajes en tiempo real.
   Usuarios se guardan también en la
   nube para permitir login desde
   cualquier dispositivo.
═══════════════════════════ */

/* ═══════════════════════════════════════════════════════════════════
   PERSISTENCIA HÍBRIDA
   - localStorage: funciona SIEMPRE, sin configuración
   - Firebase: opcional, activa los viajes compartidos en tiempo real
   
   PARA ACTIVAR FIREBASE (compartir viajes entre usuarios):
   1. Entrá a https://console.firebase.google.com/
   2. Creá un proyecto → Build → Realtime Database → Create database
      (elegí "Start in test mode")
   3. Project Settings → Your apps → </> → copiá el firebaseConfig
   4. Pegá los valores reales en FIREBASE_CONFIG acá abajo
   ═══════════════════════════════════════════════════════════════════ */

const FIREBASE_CONFIG = {
  apiKey:            "AIzaSyAU9OxfGzGCGR3K4U760TEXzDvq9gELAoA",
  authDomain:        "ucuride.firebaseapp.com",
  databaseURL:       "https://ucuride-default-rtdb.firebaseio.com",
  projectId:         "ucuride",
  storageBucket:     "ucuride.firebasestorage.app",
  messagingSenderId: "579040299576",
  appId:             "1:579040299576:web:2a49fd9599874911f234cd",
};

// ── Capa localStorage (siempre activa) ────────────────────────────────────
const LS_KEY = 'ucuride_v3';

function loadFromLocal(){
  try{
    const raw = localStorage.getItem(LS_KEY);
    if(raw){
      const data = JSON.parse(raw);
      if(data){
        usersDB = data.users || getDefaultUsers();
        ridesDB = data.rides || getDefaultRides();
        nid     = data.nid  || ridesDB.reduce((m,r)=>Math.max(m,r.id),3)+1;
        return;
      }
    }
  }catch(e){}
  usersDB = getDefaultUsers();
  ridesDB = getDefaultRides();
  nid = 100;
}

function persistLocal(){
  try{ localStorage.setItem(LS_KEY, JSON.stringify({users:usersDB, rides:ridesDB, nid})); }catch(e){}
}

// ── Compatibilidad con código existente ───────────────────────────────────
function saveDB(){
  persistLocal();
  if(firebaseReady && cu) saveUserToCloud(cu);
}
function saveRides(){
  persistLocal();
}

// ── Datos demo ─────────────────────────────────────────────────────────────
function getDefaultUsers(){
  return [{name:'Sofía Torres',email:'sofia@ucu.edu.uy',password:'123456',career:'Derecho 3er año',car:'Renault Sandero',since:'Enero 2026',trips:12,co2:21.6,stars:4.9,history:[
    {from:'Pocitos',to:'UCU Montevideo',date:'2026-05-10',price:80,co2:'1.5'},
    {from:'Punta Carretas',to:'UCU Montevideo',date:'2026-05-08',price:65,co2:'1.2'},
  ],published:[]}];
}
function getDefaultRides(){
  const today = new Date().toISOString().split('T')[0];
  return [
    {id:1,driver:'Carlos M.',from:'Pocitos',to:'UCU Montevideo',time:'07:45',date:today,seats:2,price:80,car:'VW Gol Gris',isNew:false,distKm:8.2,durMin:20,consumeL100:9},
    {id:2,driver:'Valentina R.',from:'Centro',to:'UCU Montevideo',time:'08:15',date:today,seats:3,price:55,car:'Renault Sandero Blanco',isNew:false,distKm:5.5,durMin:14,consumeL100:9},
    {id:3,driver:'Martín L.',from:'Carrasco',to:'UCU Montevideo',time:'09:00',date:today,seats:1,price:125,car:'Ford Ka Rojo',isNew:false,distKm:14.5,durMin:35,consumeL100:11},
  ];
}

// ── Variables globales ─────────────────────────────────────────────────────
let usersDB = [];
let ridesDB = [];
let nid = 100;
let cu=null, cf='todos', ttimer=null, pendId=null, editing=false;
let firebaseReady = false;
let db = null;

// Cargamos localStorage PRIMERO para que la app funcione de inmediato
loadFromLocal();

// ── Capa Firebase (opcional, se activa si FIREBASE_CONFIG tiene datos) ─────
async function initFirebase(){
  if(!FIREBASE_CONFIG.apiKey || !FIREBASE_CONFIG.databaseURL){
    console.info('ℹ️ Firebase no configurado — usando localStorage solamente.');
    return;
  }
  try{
    const { initializeApp } = await import('https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js');
    const { getDatabase, ref, set, get, onValue, remove, update } =
      await import('https://www.gstatic.com/firebasejs/10.12.2/firebase-database.js');
    const app = initializeApp(FIREBASE_CONFIG);
    db = getDatabase(app);
    window._fb = { ref, set, get, onValue, remove, update, db };
    firebaseReady = true;
    await seedDefaultRides();
    listenRides();
    console.log('✅ Firebase conectado — viajes compartidos en tiempo real');
  }catch(e){
    console.warn('⚠️ Firebase falló, continuando con localStorage:', e.message);
  }
}

function listenRides(){
  const { ref, onValue } = window._fb;
  onValue(ref(db,'rides'), (snap)=>{
    const data = snap.val();
    if(data){
      // Convertimos a array y nos aseguramos que cada objeto tiene su clave como id
      ridesDB = Object.entries(data).map(([key, ride]) => {
        // Si el id del objeto no coincide con la clave de Firebase, usamos la clave
        if(!ride.id) ride.id = key;
        return ride;
      });
    } else {
      ridesDB = [];
    }
    persistLocal();
    if(cu){ pruneExpiredRides(); updHome(); renderSearch(); }
  });
}

async function seedDefaultRides(){
  const { ref, get, set } = window._fb;
  const snap = await get(ref(db,'rides'));
  if(!snap.exists()){
    const obj = {};
    getDefaultRides().forEach(r=>{ obj[r.id]=r; });
    await set(ref(db,'rides'), obj);
  }
}

async function saveRideToCloud(ride){
  if(!firebaseReady) return;
  const { ref, set } = window._fb;
  // Usamos el firebaseKey como clave si existe, sino usamos el id local
  const key = ride.firebaseKey || String(ride.id);
  await set(ref(db,'rides/'+key), ride);
}
async function deleteRideFromCloud(id){
  if(!firebaseReady) return;
  await window._fb.remove(window._fb.ref(db,'rides/'+id));
}
async function updateRideSeats(id, seats){
  if(!firebaseReady) return;
  await window._fb.update(window._fb.ref(db,'rides/'+id), { seats });
}
async function saveUserToCloud(user){
  if(!firebaseReady) return;
  const { ref, set } = window._fb;
  const key = user.email.replace(/[.@]/g,'_');
  await set(ref(db,'users/'+key), user);
}
async function findUserInCloud(email, password){
  if(!firebaseReady) return null;
  const { ref, get } = window._fb;
  const key = email.replace(/[.@]/g,'_');
  const snap = await get(ref(db,'users/'+key));
  if(!snap.exists()) return null;
  const u = snap.val();
  return u.password===password ? u : null;
}
async function emailExistsInCloud(email){
  if(!firebaseReady) return false;
  const { ref, get } = window._fb;
  const snap = await get(window._fb.ref(db,'users/'+email.replace(/[.@]/g,'_')));
  return snap.exists();
}

// Iniciamos Firebase en segundo plano (no bloquea la app)
initFirebase();

/* ═══════════════════════════
   AUTH
═══════════════════════════ */
function showTab(t){
  document.getElementById('formLogin').style.display=t==='login'?'':'none';
  document.getElementById('formReg').style.display=t==='reg'?'':'none';
  document.getElementById('tabLogin').classList.toggle('active',t==='login');
  document.getElementById('tabReg').classList.toggle('active',t==='reg');
}

async function doLogin(){
  const e=document.getElementById('lEmail').value.trim();
  const p=document.getElementById('lPass').value;
  if(!e||!p){toast('Completá todos los campos',1);return;}
  // Primero buscamos en localStorage (siempre disponible)
  const idx=usersDB.findIndex(u=>u.email.trim()===e.trim()&&u.password===p);
  if(idx!==-1){
    cu=usersDB[idx];
    launch();
    return;
  }
  // Si está Firebase activo, también buscamos en la nube
  if(firebaseReady){
    const u = await findUserInCloud(e, p);
    if(u){
      // Lo guardamos localmente para la próxima vez
      usersDB.push(u);
      persistLocal();
      cu=usersDB[usersDB.length-1];
      launch();
      return;
    }
  }
  toast('Email o contraseña incorrectos',1);
}

async function doRegister(){
  const name=document.getElementById('rName').value.trim();
  const email=document.getElementById('rEmail').value.trim();
  const career=document.getElementById('rCareer').value.trim();
  const car=document.getElementById('rCar').value.trim();
  const pass=document.getElementById('rPass').value;
  if(!name||!email||!pass){toast('Completá los campos obligatorios',1);return;}
  if(pass.length<6){toast('Contraseña: mínimo 6 caracteres',1);return;}
  // Verificar duplicado en localStorage
  if(usersDB.find(u=>u.email.trim()===email.trim())){toast('Ese correo ya está registrado',1);return;}
  // Verificar duplicado en Firebase (si está disponible)
  if(firebaseReady){
    const exists = await emailExistsInCloud(email);
    if(exists){toast('Ese correo ya está registrado',1);return;}
  }
  const now=new Date();
  const ms=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  const nu={
    name,email,password:pass,
    career:career||'UCU',
    car:car||'—',
    since:ms[now.getMonth()]+' '+now.getFullYear(),
    trips:0,co2:0,stars:5.0,history:[],published:[]
  };
  usersDB.push(nu);
  cu = usersDB[usersDB.length-1];
  persistLocal();
  if(firebaseReady) await saveUserToCloud(cu);
  launch();
}

function launch(){
  const aw=document.getElementById('authWrap');
  aw.classList.add('gone');
  setTimeout(()=>aw.style.display='none',400);
  document.getElementById('appWrap').classList.add('visible');
  updSB();updHome();updProfilePage();renderSearch();
  updDate();
  toast('¡Bienvenido/a, '+cu.name.split(' ')[0]+'! 👋');
}

function doLogout(){
  cu=null;
  document.getElementById('appWrap').classList.remove('visible');
  const aw=document.getElementById('authWrap');
  aw.style.display='flex';aw.classList.remove('gone');
  showTab('login');
}

/* ══ EXPIRE FILTER ══ */
function isRideActive(r){
  try{return new Date(r.date+'T'+r.time+':00')>new Date();}catch(e){return true;}
}
function pruneExpiredRides(){
  // Los viajes expirados simplemente no se muestran en la UI.
  // La limpieza real en la DB se delega a Firebase (onValue los filtra).
  ridesDB=ridesDB.filter(isRideActive);
}

/* ══ NAVIGATION ══ */
const TITLES={home:'Inicio',search:'Buscar viajes',offer:'Ofrecer viaje',track:'Seguimiento',profile:'Mi perfil',benefits:'Beneficios'};
function nav(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('p-'+id).classList.add('active');
  document.querySelectorAll('[data-p]').forEach(b=>b.classList.toggle('active',b.dataset.p===id));
  document.getElementById('tbTitle').textContent=TITLES[id]||id;
  if(id==='home'){pruneExpiredRides();updHome();}
  if(id==='search'){pruneExpiredRides();renderSearch();}
  if(id==='profile'){updProfilePage();}
  if(id==='benefits'){updBenefits();}
  if(id==='track'&&trackRide){setTimeout(initLeaflet,120);}
  closeSB();
}
function openSB(){document.getElementById('sidebar').classList.add('open');document.getElementById('sbo').style.display='block';}
function closeSB(){document.getElementById('sidebar').classList.remove('open');document.getElementById('sbo').style.display='none';}
function updDate(){
  const d=new Date();const days=['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
  const ms=['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  document.getElementById('tbDate').textContent=days[d.getDay()]+' '+d.getDate()+' '+ms[d.getMonth()];
}
function updSB(){
  if(!cu)return;
  document.getElementById('sbName').textContent=cu.name;
  document.getElementById('sbRole').textContent=cu.career;
}

/* ══ HOME ══ */
function updHome(){
  if(!cu)return;
  document.getElementById('hTrips').textContent=cu.trips;
  document.getElementById('hCO2').textContent=cu.co2.toFixed(1);
  document.getElementById('hStars').textContent=cu.stars.toFixed(1);
  document.getElementById('hAvail').textContent=ridesDB.filter(isRideActive).length;
  const c=cu.co2,ml=Math.max(10,Math.ceil((c+.1)/10)*10),pct=Math.min(c/ml*100,100),tr=(c/21.7).toFixed(1);
  document.getElementById('hCO2Num').textContent=c.toFixed(1)+' kg';
  document.getElementById('hCO2Trees').textContent='= '+tr+' arboles plantados';
  document.getElementById('hCO2Bar').style.width=pct+'%';
  document.getElementById('hCO2ML').textContent='Proxima meta: '+ml+' kg';
  const active=ridesDB.filter(isRideActive);
  document.getElementById('hRides').innerHTML=active.length
    ? active.slice(0,4).map(buildCard).join('')
    : '<div class="empty"><p>No hay viajes activos en este momento.</p></div>';
}

/* ══ BENEFITS ══ */
function updBenefits(){
  if(!cu)return;
  document.getElementById('bTrips').textContent=cu.trips;
  document.getElementById('bCO2').textContent=cu.co2.toFixed(1)+' kg';
  const n=cu.trips>=5?5:cu.trips>=4?4:cu.trips>=3?3:cu.trips>=2?2:1;
  const pk=parkingDiscount(n);
  document.getElementById('bParking').textContent=pk.pct>0?pk.pct+'%':'Sin viajes aun';
}

/* ══ RIDE CARD ══ */
function buildCard(r){
  const consume=r.consumeL100||9;
  const co2=calcCO2saved(r.distKm||8,consume,Math.max(2,r.seats));
  const badge=r.isNew?`<span class="rbadge new">Nuevo</span>`:`<span class="rbadge">${r.price} UYU</span>`;
  return `<div class="ride-card ${r.isNew?'nr':''}">
    <div class="rh">
      <div class="rav"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
      <div><div class="rname">${r.driver}</div><div class="rmeta">${r.car}</div></div>
      ${badge}
    </div>
    <div class="rline">
      <div class="rp"><div class="rdot fr"></div><span class="rlbl">${r.from}</span></div>
      <div class="rdash"><span></span><span></span></div>
      <div class="rp"><div class="rdot to"></div><span class="rlbl">${r.to}</span></div>
    </div>
    <div class="rf">
      <div class="chips">
        <div class="chip"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>${r.time}</div>
        <div class="chip"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>${r.seats} asiento${r.seats!==1?'s':''}</div>
        <div class="chip" style="color:var(--green);">🌿${co2}kg CO2</div>
      </div>
      <button class="bbtn" onclick="openMod('${r.id}')">Ver viaje</button>
    </div>
  </div>`;
}

function renderSearch(){
  pruneExpiredRides();
  const q=(document.getElementById('sInput')?document.getElementById('sInput').value:'').toLowerCase();
  let f=ridesDB.filter(r=>{
    if(!isRideActive(r))return false;
    const m=!q||r.from.toLowerCase().includes(q)||r.to.toLowerCase().includes(q)||r.driver.toLowerCase().includes(q);
    if(!m)return false;
    if(cf==='todos')return true;
    const h=parseInt(r.time);
    if(cf==='manana')return h>=6&&h<12;
    if(cf==='tarde')return h>=12&&h<19;
    if(cf==='noche')return h>=19||h<6;
    return true;
  });
  const el=document.getElementById('sRides');
  if(!f.length){el.innerHTML='<div class="empty"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><p>No hay viajes disponibles.</p></div>';return;}
  f.sort((a,b)=>(b.isNew?1:0)-(a.isNew?1:0));
  el.innerHTML=f.map(buildCard).join('');
}
function setF(f,el){cf=f;document.querySelectorAll('.fc').forEach(c=>c.classList.remove('active'));el.classList.add('active');renderSearch();}

/* ══ PRICE ESTIMATOR ══ */
function estPrice(){
  const f=document.getElementById('oFrom').value.trim();
  const t=document.getElementById('oTo').value.trim();
  const seats=parseInt(document.getElementById('oSeats').value)||2;
  const consume=parseFloat(document.getElementById('oConsume').value)||9;
  if(f.length<3||t.length<3){document.getElementById('oHint').style.display='none';return;}
  const d=gd(f,t);
  const price=calcPrice(d,consume,seats);
  const co2=calcCO2saved(d,consume,seats);
  const dur=cd(d);
  const litros=(d*consume/100).toFixed(2);
  const costoTotal=(d*consume/100*FUEL_UYU).toFixed(0);
  const pk=parkingDiscount(seats);
  document.getElementById('oHint').style.display='block';
  document.getElementById('hintPrice').textContent=price;
  document.getElementById('hintKm').textContent=d.toFixed(1);
  document.getElementById('hintCO2').textContent=co2+' kg';
  document.getElementById('hintFormula').innerHTML=
    `Calculo: <b>${d.toFixed(1)} km</b> x <b>${consume} L/100km</b> = <b>${litros} L</b> x <b>$${FUEL_UYU}/L</b> = <b>$${costoTotal} total</b> / <b>${seats} personas</b> = <b style="color:var(--blue);">$${price} UYU/persona</b> · ~${dur} min`;
  document.getElementById('hintParking').innerHTML=pk.pct>0?`🅿️ Con ${seats} personas → <b>${pk.label}</b>`:'';
}

/* ══ PUBLISH ══ */
async function publishRide(){
  const from=document.getElementById('oFrom').value.trim();
  const to=document.getElementById('oTo').value.trim();
  const date=document.getElementById('oDate').value;
  const time=document.getElementById('oTime').value;
  const seats=parseInt(document.getElementById('oSeats').value)||0;
  const car=document.getElementById('oCar').value.trim();
  const consume=parseFloat(document.getElementById('oConsume').value)||9;
  if(!from||!to||!date||!time||!seats){toast('Completa los campos obligatorios',1);return;}
  const rideDate=new Date(date+'T'+time+':00');
  if(rideDate<=new Date()){toast('La fecha y hora deben ser futuras',1);return;}
  const d=gd(from,to);
  const price=calcPrice(d,consume,seats);
  const dur=cd(d);
  // Generamos un ID globalmente único: timestamp + random
  // Así nunca colisionan viajes de distintos usuarios
  const rideId = Date.now() + '_' + Math.random().toString(36).slice(2,7);
  const nr={id:rideId,driver:cu?cu.name.split(' ')[0]:'Tu',from,to,time,date,seats,price,car:car||'Mi vehiculo',isNew:true,distKm:+d.toFixed(1),durMin:dur,consumeL100:consume};
  
  // Guardamos localmente siempre
  ridesDB.unshift(nr);
  if(cu){
    cu.published=cu.published||[];
    cu.published.push({from,to,date,time,seats,price,id:rideId});
  }
  persistLocal();
  // Y en Firebase si está disponible (visible para TODOS los usuarios)
  if(firebaseReady) await saveRideToCloud(nr);
  else saveDB();

  ['oFrom','oTo','oDate','oTime','oSeats','oCar','oNote'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('oHint').style.display='none';
  document.getElementById('oConsume').value='9';
  toast('¡Viaje publicado! Todos los usuarios lo pueden ver 🚗');
  setTimeout(()=>nav('search'),1200);
}

/* ══ LEAFLET REAL MAP ══ */
let leafletMap=null,trackRide=null;
const COORDS={
  'ucu':{lat:-34.9016,lng:-56.1645},'ucu montevideo':{lat:-34.9016,lng:-56.1645},
  'pocitos':{lat:-34.9218,lng:-56.1531},'centro':{lat:-34.9058,lng:-56.1937},
  'carrasco':{lat:-34.8860,lng:-56.0436},'punta carretas':{lat:-34.9270,lng:-56.1628},
  'malvin':{lat:-34.9040,lng:-56.1200},'tres cruces':{lat:-34.8983,lng:-56.1760},
  'buceo':{lat:-34.9130,lng:-56.1418},'goes':{lat:-34.8961,lng:-56.1864},
  'la blanqueada':{lat:-34.8995,lng:-56.1820},'parque batlle':{lat:-34.9060,lng:-56.1655},
  'aguada':{lat:-34.9033,lng:-56.1900},'cordon':{lat:-34.9100,lng:-56.1800},
  'palermo':{lat:-34.9170,lng:-56.1700},
};
function getCoords(place){
  const pl=place.toLowerCase().trim();
  for(const k in COORDS){if(pl.includes(k)||k.split(' ').some(w=>w.length>3&&pl.includes(w)))return COORDS[k];}
  return {lat:-34.9058+(Math.random()*.04-.02),lng:-56.1637+(Math.random()*.04-.02)};
}
async function initLeaflet(){
  if(!trackRide||typeof L==='undefined')return;
  const mapEl=document.getElementById('leafletMap');
  if(!mapEl)return;
  if(leafletMap){leafletMap.remove();leafletMap=null;}
  const fromC=getCoords(trackRide.from),toC=getCoords(trackRide.to);
  leafletMap=L.map('leafletMap',{zoomControl:true});
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
    attribution:'© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',maxZoom:19
  }).addTo(leafletMap);
  const mkA=L.divIcon({className:'',html:`<div style="width:14px;height:14px;background:#1abc9c;border-radius:50%;border:3px solid white;box-shadow:0 2px 6px rgba(0,0,0,.4);"></div>`,iconSize:[14,14],iconAnchor:[7,7]});
  const mkB=L.divIcon({className:'',html:`<div style="width:14px;height:14px;background:#e74c3c;border-radius:50%;border:3px solid white;box-shadow:0 2px 6px rgba(0,0,0,.4);"></div>`,iconSize:[14,14],iconAnchor:[7,7]});
  const mkCar=L.divIcon({className:'',html:`<div style="width:28px;height:28px;background:#003087;border-radius:50%;border:3px solid white;display:flex;align-items:center;justify-content:center;box-shadow:0 3px 10px rgba(0,48,135,.5);font-size:14px;line-height:1;text-align:center;padding-top:5px;">🚗</div>`,iconSize:[28,28],iconAnchor:[14,14]});
  L.marker([fromC.lat,fromC.lng],{icon:mkA}).addTo(leafletMap).bindPopup(`<b>Origen:</b> ${trackRide.from}`);
  L.marker([toC.lat,toC.lng],{icon:mkB}).addTo(leafletMap).bindPopup(`<b>Destino:</b> ${trackRide.to}`);
  const carMk=L.marker([fromC.lat,fromC.lng],{icon:mkCar}).addTo(leafletMap);
  try{
    const url=`https://router.project-osrm.org/route/v1/driving/${fromC.lng},${fromC.lat};${toC.lng},${toC.lat}?overview=full&geometries=geojson`;
    const res=await fetch(url);
    const data=await res.json();
    if(data.routes&&data.routes[0]){
      const pts=data.routes[0].geometry.coordinates.map(c=>[c[1],c[0]]);
      const line=L.polyline(pts,{color:'#003087',weight:5,opacity:.85}).addTo(leafletMap);
      leafletMap.fitBounds(line.getBounds(),{padding:[24,24]});
      animateCar(carMk,pts,trackRide.durMin);
    }else throw new Error('no route');
  }catch(e){
    const pts=[[fromC.lat,fromC.lng],[toC.lat,toC.lng]];
    L.polyline(pts,{color:'#003087',weight:5,opacity:.7,dashArray:'10,6'}).addTo(leafletMap);
    leafletMap.fitBounds(pts,{padding:[40,40]});
    animateCar(carMk,pts,trackRide.durMin);
  }
}
function animateCar(marker,pts,durMin){
  let i=0;
  const iv=Math.max(50,Math.round((durMin||20)*60000/pts.length));
  const t=setInterval(()=>{if(!marker._map){clearInterval(t);return;}marker.setLatLng(pts[i%pts.length]);i++;},iv);
}

/* ═══════════════════════════
   MODAL
═══════════════════════════ */
// ── Mapa del modal (Leaflet/OpenStreetMap) ────────────────────────────────
let modMap = null;

async function initModLeaflet(r){
  if(typeof L === 'undefined') return;
  await new Promise(res => setTimeout(res, 80)); // espera que el modal esté visible

  const el = document.getElementById('modLeaflet');
  if(!el) return;
  if(modMap){ modMap.remove(); modMap = null; }

  const fromC = getCoords(r.from);
  const toC   = getCoords(r.to);

  modMap = L.map('modLeaflet', { zoomControl: false, attributionControl: false });
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 18 }).addTo(modMap);

  const mkFrom = L.divIcon({ className:'', html:`<div style="width:13px;height:13px;background:#1abc9c;border-radius:50%;border:2.5px solid white;box-shadow:0 2px 6px rgba(0,0,0,.4);"></div>`, iconSize:[13,13], iconAnchor:[6,6] });
  const mkTo   = L.divIcon({ className:'', html:`<div style="width:13px;height:13px;background:#e74c3c;border-radius:50%;border:2.5px solid white;box-shadow:0 2px 6px rgba(0,0,0,.4);"></div>`, iconSize:[13,13], iconAnchor:[6,6] });

  L.marker([fromC.lat, fromC.lng], { icon: mkFrom }).addTo(modMap).bindPopup('<b>Origen:</b> ' + r.from);
  L.marker([toC.lat,  toC.lng],  { icon: mkTo   }).addTo(modMap).bindPopup('<b>Destino:</b> ' + r.to);

  // Intentamos trazar la ruta real con OSRM
  try {
    const url = `https://router.project-osrm.org/route/v1/driving/${fromC.lng},${fromC.lat};${toC.lng},${toC.lat}?overview=full&geometries=geojson`;
    const res  = await fetch(url);
    const data = await res.json();
    if(data.routes && data.routes[0]){
      const pts  = data.routes[0].geometry.coordinates.map(c => [c[1], c[0]]);
      const line = L.polyline(pts, { color:'#003087', weight:4, opacity:.85 }).addTo(modMap);
      modMap.fitBounds(line.getBounds(), { padding:[24,24] });
    } else throw new Error('no route');
  } catch(e) {
    const pts = [[fromC.lat, fromC.lng],[toC.lat, toC.lng]];
    L.polyline(pts, { color:'#003087', weight:4, opacity:.7, dashArray:'8,5' }).addTo(modMap);
    modMap.fitBounds(pts, { padding:[30,30] });
  }
}

// Chat local por viaje (en memoria, se puede migrar a Firebase después)
let modChats = {};

function openMod(id){
  const r = ridesDB.find(r => String(r.id) === String(id));
  if(!r){ toast('Viaje no encontrado', 1); return; }
  pendId = id;

  const d   = r.distKm || gd(r.from, r.to);
  const dur  = r.durMin  || cd(d);
  const consume = r.consumeL100 || 9;
  const co2  = calcCO2saved(d, consume, Math.max(2, r.seats));

  // Textos básicos
  document.getElementById('modTitle').textContent   = r.from + ' → ' + r.to;
  document.getElementById('modDateHour').textContent = r.date + ' · ' + r.time + ' hs';
  document.getElementById('modPriceBig').textContent = r.price + ' UYU';
  document.getElementById('modDist').textContent     = '📍 ' + d.toFixed(1) + ' km';
  document.getElementById('modTime').textContent     = '⏱ ~' + dur + ' min';
  document.getElementById('modPrice').textContent    = r.price;
  document.getElementById('modKm').textContent       = d.toFixed(1);
  document.getElementById('modMin').textContent      = dur;
  document.getElementById('modCO2').textContent      = '~' + co2 + ' kg';
  document.getElementById('modDriver').textContent   = r.driver;
  document.getElementById('modCar').textContent      = r.car || '—';
  document.getElementById('modSeats').textContent    = r.seats + (r.seats === 1 ? ' asiento' : ' asientos');

  // Mapa Leaflet (OpenStreetMap, gratuito)
  initModLeaflet(r);

  // Chat
  renderModChat(id);
  document.getElementById('modChatInput').value = '';

  document.getElementById('modWrap').classList.add('open');
  loadModChat(id);
}

function closeMod(e){
  if(e.target === document.getElementById('modWrap'))
    document.getElementById('modWrap').classList.remove('open');
}

function renderModChat(id){
  const msgs = modChats[id] || [];
  const el = document.getElementById('modChat');
  if(!msgs.length){
    el.innerHTML = '<div style="text-align:center;font-size:12px;color:var(--muted);padding:10px 0;">Sé el primero en preguntar algo al conductor</div>';
    return;
  }
  el.innerHTML = msgs.map(m => {
    const isMe = cu && m.user === cu.name;
    return `<div style="display:flex;flex-direction:column;align-items:${isMe?'flex-end':'flex-start'};">
      <div style="background:${isMe?'var(--blue)':'var(--card)'};color:${isMe?'white':'var(--text)'};border-radius:${isMe?'12px 12px 3px 12px':'12px 12px 12px 3px'};padding:8px 12px;max-width:80%;font-size:13px;">${m.text}</div>
      <div style="font-size:10px;color:var(--muted);margin-top:2px;padding:0 4px;">${m.user} · ${m.time}</div>
    </div>`;
  }).join('');
  el.scrollTop = el.scrollHeight;
}

function sendModChat(){
  if(!pendId) return;
  const input = document.getElementById('modChatInput');
  const text = input.value.trim();
  if(!text) return;
  if(!modChats[pendId]) modChats[pendId] = [];
  const now = new Date();
  const time = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');
  modChats[pendId].push({ user: cu ? cu.name.split(' ')[0] : 'Anónimo', text, time });
  input.value = '';
  renderModChat(pendId);
  // Si Firebase está disponible, guardar el mensaje en la nube
  if(firebaseReady && window._fb){
    const { ref, set } = window._fb;
    set(window._fb.ref(db, 'chats/' + pendId), modChats[pendId]);
  }
}

// Cargar chats desde Firebase cuando se abre un modal
async function loadModChat(id){
  if(!firebaseReady || !window._fb) return;
  const { ref, get } = window._fb;
  const snap = await get(window._fb.ref(db, 'chats/' + String(id)));
  if(snap.exists()) modChats[id] = snap.val();
  renderModChat(id);
}

async function confirmBook(){
  document.getElementById('modWrap').classList.remove('open');
  const r=ridesDB.find(r=>String(r.id)===String(pendId));if(!r)return;
  if(r.seats<=0){toast('No quedan asientos',1);return;}
  r.seats--;
  if(r.seats===0){
    ridesDB=ridesDB.filter(x=>String(x.id)!==String(pendId));
    if(firebaseReady) await deleteRideFromCloud(pendId);
  } else {
    if(firebaseReady) await updateRideSeats(pendId, r.seats);
  }
  persistLocal();
  const d=r.distKm||8,dur=r.durMin||cd(d),consume=r.consumeL100||9,co2=parseFloat(calcCO2saved(d,consume,Math.max(2,r.seats)));
  if(cu){
    cu.co2=+(cu.co2+co2).toFixed(1);
    cu.trips++;
    cu.history=cu.history||[];
    cu.history.push({from:r.from,to:r.to,date:r.date,price:r.price,co2:co2.toFixed(1)});
    saveDB();
  }
  // update track
  document.getElementById('tDriver').textContent=r.driver;
  document.getElementById('tCar').textContent=r.car;
  document.getElementById('tETA').textContent=dur;
  document.getElementById('tFrom').textContent=r.from;
  document.getElementById('tTo').textContent=r.to;
  document.getElementById('tPrice').textContent=r.price+' UYU';
  document.getElementById('tDistInfo').textContent=d.toFixed(1)+' km';
  document.getElementById('tDist').textContent='📍 '+d.toFixed(1)+' km';
  document.getElementById('tTime').textContent='⏱ ~'+dur+' min';
  document.getElementById('tCO2').textContent='~'+calcCO2saved(d,consume,Math.max(2,r.seats))+' kg';
  document.getElementById('tTotalCO2').textContent=cu?(+cu.co2||0).toFixed(1)+' kg':'—';
  updHome();
  toast('¡Reserva confirmada! Buen viaje 🚗');
  renderSearch();
  setTimeout(()=>nav('track'),1400);
}

/* ═══════════════════════════
   PROFILE
═══════════════════════════ */
function updProfilePage(){
  if(!cu)return;
  document.getElementById('pName').textContent=cu.name;
  document.getElementById('pTag').textContent=cu.career;
  document.getElementById('pEmail').textContent=cu.email;
  document.getElementById('ppTrips').textContent=cu.trips;
  document.getElementById('ppCO2').textContent=cu.co2.toFixed(1);
  document.getElementById('ppStars').textContent=cu.stars.toFixed(1);
  document.getElementById('iName').textContent=cu.name;
  document.getElementById('iEmail').textContent=cu.email;
  document.getElementById('iCareer').textContent=cu.career;
  document.getElementById('iCar').textContent=cu.car;
  document.getElementById('iSince').textContent=cu.since;
  const c=cu.co2,ml=Math.max(10,Math.ceil((c+.1)/10)*10),pct=Math.min(c/ml*100,100),tr=(c/21.7).toFixed(1);
  document.getElementById('pCO2').textContent=c.toFixed(1)+' kg';
  document.getElementById('pTrees').textContent='= '+tr+' árboles plantados';
  document.getElementById('pCO2Bar').style.width=pct+'%';
  document.getElementById('pCO2ML').textContent='Meta: '+ml+' kg';
  // history
  const h=cu.history||[];
  document.getElementById('tripHist').innerHTML=!h.length?'<div class="empty" style="padding:14px 0;"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg><p>Tu historial aparecerá aquí</p></div>':
    h.slice().reverse().map(t=>`<div class="th-row"><div><div class="th-route">${t.from} → ${t.to}</div><div class="th-date">${t.date} · <span class="th-co2">🌿 ${t.co2} kg CO₂</span></div></div><div class="th-price">${t.price} UYU</div></div>`).join('');
  // published
  const p=cu.published||[];
  document.getElementById('myPub').innerHTML=!p.length?'<div class="empty" style="padding:10px 0;"><p style="font-size:12px;">Aún no publicaste viajes</p></div>':
    p.slice().reverse().map(r=>`<div class="th-row"><div><div class="th-route">${r.from} → ${r.to}</div><div class="th-date">${r.date} · ${r.time} · ${r.seats} asiento${r.seats!==1?'s':''}</div></div><div class="th-price">${r.price} UYU</div></div>`).join('');
}

function toggleEdit(){
  editing=!editing;
  document.getElementById('pView').style.display=editing?'none':'';
  document.getElementById('pEdit').style.display=editing?'':'none';
  document.getElementById('editBtn').textContent=editing?'✕ Cancelar':'✏️ Editar';
  if(editing){document.getElementById('eName').value=cu.name;document.getElementById('eCareer').value=cu.career;document.getElementById('eCar').value=cu.car;document.getElementById('ePass').value='';}
}
function cancelEdit(){editing=true;toggleEdit();}
function saveProfile(){
  const n=document.getElementById('eName').value.trim(),career=document.getElementById('eCareer').value.trim(),car=document.getElementById('eCar').value.trim(),pass=document.getElementById('ePass').value;
  if(!n){toast('El nombre no puede estar vacío',1);return;}
  if(pass&&pass.length<6){toast('Contraseña demasiado corta',1);return;}
  cu.name=n;cu.career=career||cu.career;cu.car=car||cu.car;if(pass.length>=6)cu.password=pass;
  // Actualizamos el objeto en usersDB
  const ui=usersDB.findIndex(u=>u.email===cu.email);
  if(ui!==-1)usersDB[ui]=cu;
  persistLocal();
  if(firebaseReady)saveUserToCloud(cu);
  editing=true;toggleEdit();updProfilePage();updSB();
  toast('✅ Perfil actualizado');
}

/* ═══════════════════════════
   TOAST
═══════════════════════════ */
function toast(msg,err){
  const t=document.getElementById('toast');
  document.getElementById('toastMsg').textContent=msg;
  t.style.background=err?'var(--red)':'var(--blue)';
  t.classList.add('show');
  if(ttimer)clearTimeout(ttimer);
  ttimer=setTimeout(()=>t.classList.remove('show'),2800);
}

/* INIT */
updDate();setInterval(updDate,60000);
</script>
</body>
</html>
